rules_version = '2';

// ═══════════════════════════════════════════════════════════════════════════
// TrustyDr Ecosystem — Firestore Security Rules
// Firebase project: doctorapp-7e8b3
//
// Surfaces covered:
//   • TrustyDr-pwa     — patient app (Flutter)
//   • doctor_portal    — doctor scheduling + center reception board (Flutter)
//   • mydoctor_admin   — global super-admin portal (Flutter)
//   • doctor_functions — Cloud Functions (Node.js / Admin SDK, bypasses rules)
//
// Role model:
//   "admin"  → users/{uid}.role == "admin"  (super-admin, set via set_admin_claim.js)
//   doctor   → doctors/{uid} document exists (uid == Firebase Auth UID)
//   patient  → authenticated user who is not a doctor
//   center staff → medical_centers/{centerId}/members/{uid} exists
//
// ═══════════════════════════════════════════════════════════════════════════

service cloud.firestore {
  match /databases/{database}/documents {


    // ───────────────────────────────────────────────────────────────────────
    // HELPER FUNCTIONS
    // ───────────────────────────────────────────────────────────────────────

    function isSignedIn() {
      return request.auth != null;
    }

    // Super-admin: users/{uid}.role == "admin"
    // Costs 1 document read per rule evaluation.
    function isAdmin() {
      return isSignedIn()
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin";
    }

    // Doctor: a doctors/{uid} document exists for the caller.
    // Costs 1 exists() check per rule evaluation.
    function isDoctor() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/doctors/$(request.auth.uid));
    }

    // Diagnostic provider: a diagnostic_providers/{uid} document exists for the caller.
    // Used to grant the same center-creation rights as isDoctor() without
    // touching doctors/{uid}, which diagnostic providers do not have.
    function isDiagnosticProvider() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/diagnostic_providers/$(request.auth.uid));
    }

    // Center staff: caller has a member doc in the given center.
    function isCenterMember(centerId) {
      return isSignedIn()
        && exists(/databases/$(database)/documents/medical_centers/$(centerId)/members/$(request.auth.uid));
    }

    // Center owner: caller's uid matches the center's ownerId field.
    function isCenterOwner(centerId) {
      return isSignedIn()
        && get(/databases/$(database)/documents/medical_centers/$(centerId)).data.ownerId == request.auth.uid;
    }

    // Center admin (unscoped): caller's users doc has centerRole == 'center_admin'.
    // Use for read-only rules where the specific center is embedded in each document
    // (e.g. doctors list query where centerId is in the document, not the rule path).
    // Costs 1 document read per rule evaluation.
    function isCenterAdmin() {
      return isSignedIn()
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('centerRole', '') == 'center_admin';
    }

    // Center admin scoped to a specific centerId.
    // Use wherever the target center is known from the rule path or resource data.
    // Prevents a center admin of one center from acting on another center.
    // Costs 1 document read per rule evaluation.
    function isCenterAdminForCenter(centerId) {
      let userDoc = get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
      return isSignedIn()
        && userDoc.get('centerRole', '') == 'center_admin'
        && userDoc.get('centerId', '') == centerId;
    }

    // Center admin via members subcollection — source of truth for billing access.
    // Reads medical_centers/{centerId}/members/{uid} directly; more reliable than
    // users.centerRole which may be absent for some doctor-owned center members.
    // centerId null-guard prevents path-building errors on documents without centerId.
    // exists() guard prevents null-access when the member doc is absent.
    function isCenterAdminMember(centerId) {
      return isSignedIn()
        && centerId is string
        && centerId.size() > 0
        && exists(/databases/$(database)/documents/medical_centers/$(centerId)/members/$(request.auth.uid))
        && get(/databases/$(database)/documents/medical_centers/$(centerId)/members/$(request.auth.uid)).data.get('role', '') == 'center_admin'
        && get(/databases/$(database)/documents/medical_centers/$(centerId)/members/$(request.auth.uid)).data.get('isActive', false) == true;
    }

    // Center owner OR scoped center admin may update exactly the three
    // doctor-to-center link fields (centerId, centerJoinStatus, centerJoinApprovedAt).
    // Approve flow: centerId is being set — verifies ownership/admin of the new center.
    // Remove flow:  centerId is being cleared — verifies ownership/admin of current center.
    function isDoctorCenterLinkUpdate() {
      let newCenterId = request.resource.data.get('centerId', null);
      let oldCenterId = resource.data.get('centerId', null);
      let targetId = newCenterId != null ? newCenterId : oldCenterId;
      return isSignedIn()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
             'centerId', 'centerJoinStatus', 'centerJoinApprovedAt'
           ])
        && targetId != null
        && (isCenterOwner(targetId) || isCenterAdminForCenter(targetId));
    }

    // Center staff may mark an appointment unpaid → paid.
    // amountPaid and paymentMethod are required alongside the audit fields.
    // receiptRef is optional — included in hasOnly so it may be written when present.
    // No other fields may change. Caller must be a member of the appointment's center.
    function isPaymentStatusUpdate(centerId) {
      return isSignedIn()
        && isCenterMember(centerId)
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
             'paymentStatus', 'paymentStatusUpdatedAt',
             'paymentStatusUpdatedBy', 'updatedAt',
             'amountPaid', 'paymentMethod', 'receiptRef'
           ])
        && resource.data.paymentStatus == 'unpaid'
        && request.resource.data.paymentStatus == 'paid'
        && request.resource.data.paymentStatusUpdatedBy == request.auth.uid
        && request.resource.data.amountPaid > 0;
    }

    // Path B (reception/walk-in) may create as unpaid or pre-paid.
    // Pre-paid requires identity and method audit; patient app is always unpaid.
    function isValidCreationPayment() {
      return request.resource.data.paymentStatus == 'unpaid'
        || (request.resource.data.paymentStatus == 'paid'
            && request.resource.data.paymentStatusUpdatedBy == request.auth.uid
            && request.resource.data.get('paymentMethod', '') == 'front_desk_cash');
    }

    // Center is operationally active: now falls within trial, subscription,
    // or grace period window. Mirrors centerAccessProvider date-only logic.
    // Returns false (fail-closed) if all date fields are absent.
    function centerIsOperational(centerId) {
      let center = get(/databases/$(database)/documents/medical_centers/$(centerId));
      let now = request.time;
      let trialEnds = center.data.get('trialEnds', null);
      let subscriptionEnd = center.data.get('subscriptionEnd', null);
      let gracePeriodEnds = center.data.get('gracePeriodEnds', null);
      return (trialEnds != null && now < trialEnds)
        || (subscriptionEnd != null && now < subscriptionEnd)
        || (gracePeriodEnds != null && now < gracePeriodEnds);
    }

    // Fields on doctors/{uid} that only Cloud Functions / admin may write.
    // Doctors cannot self-escalate their subscription or verification status.
    //
    // Exception: the doctor may accept legal consent, which transitions
    // status from 'legalConsent' → 'onboarding'. This is the only permitted
    // client-side status write; all other status changes remain admin-only.
    function isLegalConsentTransition() {
      return resource.data.status == 'legalConsent'
        && request.resource.data.status == 'onboarding'
        && request.resource.data.get('legalAccepted', false) == true;
    }

    // Doctor submits completed onboarding for admin review.
    // Allowed ONLY when transitioning onboarding → pending and all privilege
    // flags are explicitly set to false (no self-escalation possible).
    function isOnboardingSubmitTransition() {
      return resource.data.status == 'onboarding'
        && request.resource.data.status == 'pending'
        && request.resource.data.get('submittedAt', null) != null
        && request.resource.data.isActive == false
        && request.resource.data.isVerified == false
        && request.resource.data.canBook == false
        && request.resource.data.canCall == false;
    }

    // A lab/imaging provider writes diagnostic_providers/{uid} and simultaneously
    // marks their stale doctors/{uid} draft as converted. This is the only path
    // where status may move from onboarding → converted_to_diagnostic_provider
    // from the client. Privilege-escalation fields must not be touched.
    function isConvertedToProviderTransition() {
      return resource.data.get('status', '') == 'onboarding'
        && request.resource.data.status == 'converted_to_diagnostic_provider'
        && !request.resource.data.diff(resource.data).affectedKeys().hasAny([
             'isActive', 'isVerified', 'verificationStatus',
             'canBook', 'canCall',
             'isPaidUser', 'subscriptionStatus', 'subscriptionPlan',
             'nextBillingDate', 'trialStart', 'trialEnds'
           ]);
    }

    function touchesDoctorAdminFields() {
      return !isLegalConsentTransition()
        && !isOnboardingSubmitTransition()
        && !isConvertedToProviderTransition()
        && request.resource.data.diff(resource.data).affectedKeys().hasAny([
          'isPaidUser', 'subscriptionStatus', 'subscriptionPlan',
          'nextBillingDate', 'trialStart', 'trialEnds',
          'isActive', 'isVerified', 'verificationStatus',
          'canBook', 'canCall', 'status'
        ]);
    }

    // Phase 2B: patient release of clinical results is doctor-only.
    // Defined here so the helper name is available at all call sites.
    // When multi-doctor or center-admin release is approved, expand this function.
    function canReleaseClinicalResults(centerId) {
      return isDoctor();
    }

    // ── Lab helper functions ─────────────────────────────────────────────────
    // Scoped to diagnostic_providers/{labId}/lab_members — separate subcollection
    // from center 'members', so no collectionGroup collision is possible.

    // Lab member: caller has an active lab_members doc in the given lab.
    function isLabMember(labId) {
      return isSignedIn()
        && exists(/databases/$(database)/documents/diagnostic_providers/$(labId)/lab_members/$(request.auth.uid));
    }

    // Lab owner: the diagnostic_providers doc's userId matches the caller.
    function isLabOwner(labId) {
      return isSignedIn()
        && get(/databases/$(database)/documents/diagnostic_providers/$(labId)).data.userId == request.auth.uid;
    }

    // Returns the partnerProviderId of a clinical_request document (empty string
    // if the field is absent).  Used in attachment READ path 4 to avoid referencing
    // resource.data.centerId — a resource.data reference without a corresponding
    // where() constraint in the query would cause Firestore to reject the whole list
    // query even when another allow rule (e.g. READ path 2) would grant access.
    function labProviderForRequest(reqId) {
      return get(/databases/$(database)/documents/clinical_requests/$(reqId))
               .data.get('partnerProviderId', '');
    }

    // Lab admin via lab_members subcollection — source of truth for admin access.
    // Mirrors isCenterAdminMember: cannot be spoofed by editing users/{uid} fields.
    function isLabAdminMember(labId) {
      return isSignedIn()
        && labId is string
        && labId.size() > 0
        && exists(/databases/$(database)/documents/diagnostic_providers/$(labId)/lab_members/$(request.auth.uid))
        && get(/databases/$(database)/documents/diagnostic_providers/$(labId)/lab_members/$(request.auth.uid)).data.get('role', '') == 'lab_admin'
        && get(/databases/$(database)/documents/diagnostic_providers/$(labId)/lab_members/$(request.auth.uid)).data.get('isActive', false) == true;
    }

    // Detects whether a write touches the accountLifecycle sub-object.
    // Used to block client-side lifecycle writes — only Cloud Functions (admin SDK)
    // may write accountLifecycle. Admin SDK bypasses rules entirely.
    //
    // For creates (resource == null): check if accountLifecycle appears in the
    // new document's keys. diff() requires a non-null resource so cannot be used.
    // For updates (resource != null): check if accountLifecycle is in the diff.
    function touchesLifecycle() {
      return resource == null
        ? request.resource.data.keys().hasAny(['accountLifecycle'])
        : request.resource.data.diff(resource.data).affectedKeys()
            .hasAny(['accountLifecycle']);
    }

    // Core identity fields on an appointment that must never change after creation.
    // patientHealthSnapshot is immutable — health context is fixed at booking time.
    function appointmentCoreUnchanged() {
      return !request.resource.data.diff(resource.data).affectedKeys().hasAny([
        'patientId', 'doctorId', 'centerId', 'source',
        'bookedByUserId', 'bookedByRole', 'appointmentAt',
        'dateKey', 'slotId', 'createdAt', 'patientHealthSnapshot'
      ]);
    }

    // Validates the embedded health snapshot written at booking time.
    //   null  → family/relative booking or missing profile — always allowed.
    //   map   → self-booking snapshot; must be schemaVersion 1 and must NOT
    //           include dateOfBirth (DOB is never stored in appointment documents).
    function validHealthSnapshot(snap) {
      return snap == null
        || (snap is map
            && snap.get('schemaVersion', 0) == 1
            && !snap.keys().hasAny(['dateOfBirth']));
    }


    // Patient releases their own slot lock when cancelling a self-booked
    // lab/imaging appointment. slot_locks.appointmentId for lab bookings
    // points to clinical_requests (not appointments). Verifies ownership
    // via clinical_requests to prevent cross-patient slot manipulation.
    // partnerStatus guard prevents releasing locks for already-terminal bookings.
    // Only 1 Firestore read — the let binding caches the document.
    function isPatientLabSlotCancel() {
      let apptId = resource.data.get('appointmentId', '');
      let cr = get(/databases/$(database)/documents/clinical_requests/$(apptId)).data;
      return apptId.size() > 0
        && cr.get('patientId', '') == request.auth.uid
        && cr.get('source', '') == 'scheduled'
        && cr.get('createdByRole', '') == 'patient'
        && cr.get('partnerStatus', '') in ['pendingApproval', 'scheduled'];
    }

    // ───────────────────────────────────────────────────────────────────────
    // REFERENCE DATA  (public read — cities, provinces, specialties)
    // ───────────────────────────────────────────────────────────────────────

    match /specialties/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /provinces/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /cities/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ───────────────────────────────────────────────────────────────────────
    // public_daily_health_weather/{provinceKey}
    //
    // Environmental awareness data — cached province-level summaries written
    // once daily by the scheduleDailyHealthWeather Cloud Function (Admin SDK,
    // which bypasses these rules entirely).
    //
    // Read:  public — no auth required (environmental data, no PII).
    // Write: Admin SDK only in normal operation.
    //        isAdmin() guard allows super-admin manual override if needed
    //        (e.g., correcting a stale document without redeploying the function).
    //
    // No user data is stored in this collection.
    // ───────────────────────────────────────────────────────────────────────

    match /public_daily_health_weather/{provinceKey} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ───────────────────────────────────────────────────────────────────────
    // public_home_announcements/{id}
    //
    // General-awareness dashboard cards shown in the patient home screen.
    // Contains no PII — purely editorial content (clinic schedules, health
    // campaigns, system notices).
    //
    // Read:  public — no auth required.
    // Write: super-admin only (manual Firestore console or admin portal).
    //        Admin SDK Cloud Functions also bypass these rules if needed.
    // ───────────────────────────────────────────────────────────────────────

    match /public_home_announcements/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }


    // ───────────────────────────────────────────────────────────────────────
    // users/{uid}
    //
    // Read:   own doc, admin (patient_directory), or doctor (phone search)
    // Create: own doc only; cannot self-assign "admin" role
    // Update: own doc (cannot escalate to admin); admin unrestricted
    // ───────────────────────────────────────────────────────────────────────

    match /users/{uid} {
      allow read: if isSignedIn()
        && (request.auth.uid == uid
            || isAdmin()
            || isDoctor());

      allow create: if isSignedIn()
        && request.auth.uid == uid
        && (!request.resource.data.keys().hasAny(['role'])
            || request.resource.data.role != 'admin');

      // accountLifecycle is controlled exclusively by Cloud Functions (admin SDK).
      // No client path — including admin portal — may write this sub-object.
      allow update: if !touchesLifecycle()
        && (isAdmin()
            || (isSignedIn()
                && request.auth.uid == uid
                && (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['role'])
                    || request.resource.data.role != 'admin')));

      // ── users/{uid}/notifications ──────────────────────────────────────────
      // Appointment reminder notifications written by Cloud Functions (Admin SDK).
      // Patient reads own subcollection only.
      // Patient may flip isRead — no other field may be changed from the client.
      // create/delete are always false: only Cloud Functions write these docs.
      match /notifications/{notifId} {
        allow read:   if isSignedIn() && request.auth.uid == uid;
        allow update: if isSignedIn()
                      && request.auth.uid == uid
                      && request.resource.data.diff(resource.data)
                           .affectedKeys().hasOnly(['isRead', 'dismissed', 'dismissedAt']);
        allow create: if false;
        allow delete: if false;
      }

      // ── users/{uid}/fcmTokens ──────────────────────────────────────────────
      // FCM push tokens — one doc per device, managed by the patient app.
      // Cloud Functions use Admin SDK (bypass rules) for stale-token cleanup.
      // Patient may read/create/update/delete only their own token docs.
      match /fcmTokens/{tokenId} {
        allow read, write: if isSignedIn() && request.auth.uid == uid;
      }
    }


    // ───────────────────────────────────────────────────────────────────────
    // doctors/{uid}
    //
    // Read:   own doc, admin, or another verified doctor (portal use).
    //         Patients rely on public_doctors/{uid} — a safe projection that
    //         excludes phone, email, nationalId, license docs, and billing.
    //         Tightened from isSignedIn() to block patient-side direct reads.
    // Create: doctor self-registration (uid must match)
    // Update: doctor updates own profile fields; admin updates any field
    //         Protected fields (touchesDoctorAdminFields): only admin / Cloud Functions
    //
    // Subcollection: doctors/{uid}/reviews
    // ───────────────────────────────────────────────────────────────────────

    match /doctors/{uid} {
      // isCenterAdmin() allows non-doctor center managers to read doctor
      // profiles for center management (pending requests, approved doctors list).
      allow read: if isSignedIn()
        && (request.auth.uid == uid || isAdmin() || isDoctor() || isCenterAdmin());

      allow create: if isSignedIn()
        && request.auth.uid == uid;

      // accountLifecycle is controlled exclusively by Cloud Functions (admin SDK).
      allow update: if !touchesLifecycle()
        && (isAdmin()
            || (isSignedIn()
                && request.auth.uid == uid
                && !touchesDoctorAdminFields())
            // Center owner or scoped center admin may link/unlink a doctor during
            // the join-request approve and remove flows (ManageDoctors tab).
            || isDoctorCenterLinkUpdate());


      // ── doctors/{uid}/reviews ──────────────────────────────────────────
      // Patients (non-doctors) may create one review per visit.
      // Reviews are immutable after creation (update/delete = admin only).
      match /reviews/{reviewId} {
        allow read: if true;

        allow create: if isSignedIn()
          && !isDoctor()
          && request.resource.data.userId == request.auth.uid;

        allow update, delete: if isAdmin();
      }

    }


    // ───────────────────────────────────────────────────────────────────────
    // schedules/{scheduleId}
    //
    // Read:   published schedules (patient app) OR own schedules (doctor portal)
    // Create: doctor only; doctorId field must match caller's uid
    // Update: doctor who owns the schedule
    // Delete: owning doctor or admin
    // ───────────────────────────────────────────────────────────────────────

    match /schedules/{scheduleId} {
      // Published active schedules are publicly readable — guest availability browsing.
      // Unpublished and inactive schedules remain private.
      // For diagnostic providers: doctorId = labId (piggyback model — reuses schedule system).
      // Lab staff read their published schedule via isLabMember; lab owner covered by doctorId check.
      allow read: if (resource.data.status == 'published' && resource.data.isActive == true)
        || (isSignedIn() && (resource.data.doctorId == request.auth.uid || isAdmin()))
        // Lab/imaging reception reads the lab's published schedule (doctorId = labId piggyback).
        || (isSignedIn()
            && resource.data.get('status', '') == 'published'
            && isLabMember(resource.data.centerId));

      allow create: if isDoctor()
        && request.resource.data.doctorId == request.auth.uid
        && centerIsOperational(request.resource.data.centerId);

      allow update: if isDoctor()
        && resource.data.doctorId == request.auth.uid
        && centerIsOperational(resource.data.centerId);

      // Client-side delete is only permitted for draft shifts.
      // Published shifts are deleted exclusively by the guardPublishDrafts /
      // guardDeleteShift / guardResetWeek / guardClearDay Cloud Functions
      // (which use the Admin SDK and bypass these rules).
      allow delete: if ((isDoctor() && resource.data.doctorId == request.auth.uid
                         && resource.data.get('status', 'draft') != 'published')
                        || isAdmin());
    }


    // ───────────────────────────────────────────────────────────────────────
    // appointments/{appointmentId}
    //
    // CREATE — two paths:
    //   Path A: patient self-booking (patient app)
    //   Path B: center staff / doctor booking walk-in or follow-up (doctor portal)
    //
    // READ:  patient (own), doctor (own), center staff, admin
    //
    // UPDATE — three roles with different field permissions:
    //   Doctor   → any non-core field (status, visitStatus, paymentStatus, notes…)
    //   Center staff → visitStatus, paymentStatus, status, notes, timestamps
    //   Patient  → status:'cancelled' + cancelledAt only
    //   Admin    → unrestricted
    // ───────────────────────────────────────────────────────────────────────

    match /appointments/{appointmentId} {

      allow read: if isSignedIn()
        && (resource == null
            || resource.data.patientId == request.auth.uid
            || resource.data.doctorId == request.auth.uid
            || isCenterMember(resource.data.centerId)
            || isAdmin());

      // ── Path A: patient self-booking ──────────────────────────────────
      // patientHealthSnapshot may be null (missing profile) or a valid snapshot
      // map (self-booking with health data). dateOfBirth is always excluded.
      allow create: if isSignedIn()
        && request.resource.data.source == 'patient_app'
        && request.resource.data.patientId == request.auth.uid
        && request.resource.data.bookedByUserId == request.auth.uid
        && request.resource.data.bookedByRole == 'patient'
        && request.resource.data.status == 'pending'
        && request.resource.data.paymentStatus == 'unpaid'
        && request.resource.data.visitStatus == 'waiting'
        && centerIsOperational(request.resource.data.centerId)
        && validHealthSnapshot(request.resource.data.get('patientHealthSnapshot', null));

      // ── Path B: center staff / doctor walk-in or follow-up booking ────
      // Reception has no access to patient_health_profiles.
      // patientHealthSnapshot must always be null for Path B writes.
      // Payment may be unpaid (default) or paid-at-creation with audit trail.
      allow create: if isSignedIn()
        && request.resource.data.source in ['walk_in', 'reception', 'doctor_followup']
        && request.resource.data.bookedByUserId == request.auth.uid
        && isCenterMember(request.resource.data.centerId)
        && request.resource.data.status in ['pending', 'confirmed']
        && request.resource.data.visitStatus == 'waiting'
        && centerIsOperational(request.resource.data.centerId)
        && request.resource.data.get('patientHealthSnapshot', null) == null
        && isValidCreationPayment();

      // ── Doctor: update own appointment (status, visitStatus, notes) — paymentStatus excluded ─
      allow update: if isSignedIn()
        && resource.data.doctorId == request.auth.uid
        && appointmentCoreUnchanged()
        && !request.resource.data.diff(resource.data).affectedKeys().hasAny([
             'paymentStatus', 'paymentStatusUpdatedAt', 'paymentStatusUpdatedBy'
           ]);

      // ── Center staff: lifecycle updates (visitStatus, status, notes) ──────
      allow update: if isSignedIn()
        && isCenterMember(resource.data.centerId)
        && appointmentCoreUnchanged()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
             'visitStatus', 'status', 'notes',
             'updatedAt', 'confirmedAt', 'cancelledAt', 'completedAt'
           ]);

      // ── Center staff: payment marking (unpaid → paid, audit fields required) ─
      allow update: if appointmentCoreUnchanged()
        && isPaymentStatusUpdate(resource.data.centerId);

      // ── Patient: cancel own appointment only (pending or confirmed, not completed) ──
      allow update: if isSignedIn()
        && resource.data.patientId == request.auth.uid
        && resource.data.status != 'completed'
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
             'status', 'cancelledAt', 'updatedAt'
           ])
        && request.resource.data.status == 'cancelled';

      // ── Patient: mark own completed appointment as reviewed (one-way) ─
      allow update: if isSignedIn()
        && resource.data.patientId == request.auth.uid
        && resource.data.status == 'completed'
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
             'hasReviewed', 'updatedAt'
           ])
        && request.resource.data.hasReviewed == true;

      // ── Admin: full update access ──────────────────────────────────────
      allow update: if isAdmin();
    }


    // ───────────────────────────────────────────────────────────────────────
    // paymentTransactions/{txId}
    //
    // Immutable financial event log.  One document per payment event.
    // Written atomically with the appointment update via WriteBatch.
    //
    // Phase 1 — payment only.  Refund support is deferred; type == 'refund'
    // is blocked here until a full refund UI + workflow is implemented.
    //
    // READ  — center members (own center only) or the patient on the record
    // CREATE — center members only; type must be 'payment'; amount > 0
    // UPDATE — permanently forbidden
    // DELETE — permanently forbidden
    // ───────────────────────────────────────────────────────────────────────

    match /paymentTransactions/{txId} {

      allow read: if isSignedIn()
        && (isCenterMember(resource.data.centerId)
            || resource.data.patientId == request.auth.uid
            || isAdmin());

      allow create: if isSignedIn()
        && isCenterMember(request.resource.data.centerId)
        && request.resource.data.createdBy == request.auth.uid
        && request.resource.data.status == 'completed'
        && request.resource.data.amount > 0
        && request.resource.data.currency == 'IQD'
        && request.resource.data.type == 'payment'
        && request.resource.data.chargeType in [
             'consultation', 'lab', 'procedure',
             'medication', 'pharmacy', 'other'
           ];

      allow update: if false;
      allow delete: if false;
    }


    // ───────────────────────────────────────────────────────────────────────
    // slot_locks/{slotId}
    //
    // Transient availability records — one per booked slot.
    // Created atomically with the appointment document at booking time.
    // Deleted atomically with the appointment status update at cancellation.
    //
    // SlotId format: '{scheduleId}_{slotStartAt.millisecondsSinceEpoch}'
    //
    // Presence  → slot is occupied.
    // Absence   → slot is available.
    //
    // Required fields written at create time:
    //   appointmentId — UUID of the linked appointment document
    //   centerId      — center scope (used for member permission check + index)
    //   dateKey       — YYYY-MM-DD (used for getBookedSlotIds index query)
    //   lockedBy      — request.auth.uid of the booking actor
    //   lockedAt      — FieldValue.serverTimestamp()
    //
    // Read:   any signed-in user — the booking transaction must read
    //         slot_locks/{slotId} to check availability before writing.
    // Create: any signed-in user who identifies themselves as the locker
    //         (lockedBy == auth.uid). Covers both patient self-booking and
    //         center-staff booking; appointment creation rules enforce the
    //         deeper source / role / ownership constraints atomically.
    // Delete: the original lock creator (lockedBy == auth.uid), the patient
    //         who owns the linked appointment (enables patient-initiated
    //         cancellation of reception-booked slots where lockedBy is staff),
    //         any active center member for that center, or admin.
    //         When resource == null the document does not exist; the delete is
    //         a no-op (walk-in appointments and pre-Phase-1 appointments have
    //         no slot_lock). Any signed-in user may safely attempt it.
    //         All cancellation surfaces delete the lock in the same batch/
    //         transaction as the appointment status update.
    // Update: never — locks are created and deleted only, not mutated.
    // ───────────────────────────────────────────────────────────────────────

    match /slot_locks/{slotId} {
      allow read: if isSignedIn();

      allow create: if isSignedIn()
        && request.resource.data.lockedBy == request.auth.uid
        && request.resource.data.centerId is string
        && request.resource.data.centerId.size() > 0
        && request.resource.data.appointmentId is string
        && request.resource.data.dateKey is string;

      allow delete: if isSignedIn()
        && (resource == null
            // Booking creator (covers all cancel surfaces — patient, staff, reception)
            || resource.data.lockedBy == request.auth.uid
            // Patient cancels own self-booked lab/imaging appointment.
            // Explicit clinical_requests path — appointmentId in slot_locks
            // for lab bookings points to clinical_requests, not appointments.
            || isPatientLabSlotCancel()
            // Doctor appointment cancel: appointmentId points to appointments/{id}
            || (resource.data.appointmentId is string
                && get(/databases/$(database)/documents/appointments/$(resource.data.appointmentId)).data.patientId == request.auth.uid)
            || isCenterMember(resource.data.centerId)
            || isAdmin());

      allow update: if false;
    }


    // ───────────────────────────────────────────────────────────────────────
    // patient_referral_requests/{referralId}
    //
    // Safe patient-facing view of a doctor-created external partner referral.
    // Document ID == clinical_requests doc ID (same key for easy cross-reference).
    //
    // Security model:
    //   This document intentionally contains ONLY safe referral metadata:
    //   provider info, service name, instructions, and live status fields.
    //   It NEVER contains resultNote, resultItems, technician notes, attachments,
    //   or any unreleased clinical data.
    //
    //   All writes are performed by Cloud Functions (Admin SDK bypasses rules).
    //   No client writes are permitted.
    //   clinical_requests rules are UNCHANGED — patients never read that collection
    //   via this flow.
    //
    // Read access:
    //   Patient reads own referral documents only (patientId == auth.uid).
    //   Admin reads for support.
    // ───────────────────────────────────────────────────────────────────────

    match /patient_referral_requests/{referralId} {
      // Patient reads their own referral view.
      allow read: if isSignedIn()
        && resource.data.patientId == request.auth.uid;

      // Admin reads for support.
      allow read: if isAdmin();

      // All writes via Cloud Functions (Admin SDK — no rule required).
      allow write: if false;
    }


    // ───────────────────────────────────────────────────────────────────────
    // patient_visit_notes/{appointmentId}
    //
    // Document ID == appointmentId (deterministic: one note per appointment).
    //
    // Privacy model:
    //   Doctor who wrote the note → get + list + create + update
    //   Admin                     → read (get + list) only
    //   Center staff/reception    → intentionally NO access (clinical notes)
    //   Patient app               → intentionally NO access (MVP)
    //
    // GET vs LIST split:
    //   get  — note may not exist yet (first visit). When resource == null,
    //          authorize via appointments/{appointmentId}.doctorId instead.
    //   list — history query; document always exists, so resource.data is safe.
    //
    // Immutable core fields: patientId, doctorId, centerId, appointmentId,
    //   createdAt, createdByUserId, createdByRole, schemaVersion
    // Mutable fields: clinicalNote, followUpNote, updatedAt
    // ───────────────────────────────────────────────────────────────────────

    match /patient_visit_notes/{appointmentId} {

      // GET a single note document (doctor or admin).
      // Case 1: note exists — verify doctorId ownership directly.
      // Case 2: note does not exist yet (first visit before any note is saved) —
      //         cross-reference the appointment document to verify ownership.
      //         noteId == appointmentId so no extra lookup key is needed.
      //         Cost: 1 extra read on appointments/{appointmentId} only when
      //         the note is absent; zero extra reads once the note exists.
      allow get: if isSignedIn() && (
          (resource != null && resource.data.doctorId == request.auth.uid)
          || (resource == null
              && get(/databases/$(database)/documents/appointments/$(appointmentId)).data.doctorId == request.auth.uid)
        );

      // LIST (patient history query) — documents always exist in queries,
      // so resource.data is safe. Doctor sees only their own notes.
      allow list: if isSignedIn()
        && resource.data.doctorId == request.auth.uid;

      // Admin can get + list all notes.
      allow read: if isAdmin();

      // Doctor creates a note — ownership + schema validation.
      // appointmentId field must match the document ID to prevent ID spoofing.
      allow create: if isSignedIn()
        && isDoctor()
        && request.resource.data.doctorId == request.auth.uid
        && request.resource.data.appointmentId == appointmentId
        && request.resource.data.createdByUserId == request.auth.uid
        && request.resource.data.createdByRole == 'doctor'
        && request.resource.data.schemaVersion == 1
        && request.resource.data.clinicalNote is string;

      // Doctor may update only the clinical content of their own note.
      allow update: if isSignedIn()
        && resource.data.doctorId == request.auth.uid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
             'clinicalNote', 'followUpNote', 'updatedAt'
           ]);

      // Notes are permanent records — no client-side delete.
    }


    // ───────────────────────────────────────────────────────────────────────
    // patient_health_profiles/{patientId}
    //
    // Optional health context entered by the patient: date of birth, gender,
    // blood type, allergies, chronic conditions, current medications.
    //
    // Privacy model:
    //   Patient    → get own document only (no list — prevents enumeration)
    //   Admin      → read only (compliance audit)
    //   Doctor     → NO direct access to this collection
    //   Reception  → NO access
    //
    // Doctors read health data only through appointments/{id}.patientHealthSnapshot,
    // which is embedded at booking time for self-bookings.
    // This prevents any doctor from listing or querying all patients' health profiles.
    //
    // Document ID == patientId (one document per patient, deterministic).
    //
    // Immutable after creation: patientId, schemaVersion
    // Mutable:                  dateOfBirth, gender, bloodType, allergies,
    //                           chronicConditions, currentMedications, updatedAt
    // ───────────────────────────────────────────────────────────────────────

    match /patient_health_profiles/{patientId} {

      // Patient reads only their own profile.
      // 'get' only — 'list' is intentionally absent to block collection enumeration.
      allow get: if isSignedIn()
        && request.auth.uid == patientId;

      // Patient creates their own profile.
      // patientId field must match document ID and caller uid.
      // schemaVersion must be 1 on creation.
      allow create: if isSignedIn()
        && request.auth.uid == patientId
        && request.resource.data.patientId == patientId
        && request.resource.data.schemaVersion == 1;

      // Patient updates mutable fields only.
      // patientId and schemaVersion cannot change after creation.
      allow update: if isSignedIn()
        && request.auth.uid == patientId
        && request.resource.data.patientId == resource.data.patientId
        && request.resource.data.schemaVersion == resource.data.schemaVersion
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
             'dateOfBirth', 'gender', 'bloodType',
             'allergies', 'chronicConditions', 'currentMedications',
             'updatedAt'
           ]);

      // No client-side delete — patients clear data by nulling fields via update.
      allow delete: if false;

      // Admin read for compliance audit.
      allow read: if isAdmin();
    }


    // ───────────────────────────────────────────────────────────────────────
    // medical_centers/{centerId}
    //
    // Read:   public for active centers (isActive == true); inactive centers private
    // Create: doctor only; ownerId must match caller; billing fields allowed on
    //         initial creation (doctor sets subscriptionStatus, trialStart, etc.)
    // Update: center owner may update profile fields BUT NOT billing/subscription
    //         fields (those are admin-only to prevent self-upgrade fraud).
    //         Admin may update any field (subscription activation on payment).
    //
    // Subcollection: medical_centers/{centerId}/members/{uid}
    // ───────────────────────────────────────────────────────────────────────

    match /medical_centers/{centerId} {
      // Active centers: public read (no auth required) — used for center discovery.
      // Owner/member: can read even when isActive == false (e.g. billing page on inactive center).
      // resource == null: allow GET on non-existent docs (returns exists=false, not permission-denied).
      allow read: if resource == null
        || resource.data.get('isActive', false) == true
        || (isSignedIn() && resource.data.ownerId == request.auth.uid)
        || (isSignedIn() && isCenterMember(centerId));

      // Billing fields permitted on creation (doctor or diagnostic provider sets up initial trial).
      // These same fields are blocked from updates by the owner below.
      allow create: if (isDoctor() || isDiagnosticProvider())
        && request.resource.data.ownerId == request.auth.uid;

      // accountLifecycle is controlled exclusively by Cloud Functions (admin SDK).
      allow update: if !touchesLifecycle()
        && (isAdmin()
            || (isSignedIn()
                && resource.data.ownerId == request.auth.uid
                && !request.resource.data.diff(resource.data).affectedKeys().hasAny([
                     'subscriptionStatus', 'centerStatus',
                     'trialStart', 'trialEnds',
                     'nextBillingDate', 'subscriptionStart', 'subscriptionEnd',
                     'currentPlan', 'billingCycle', 'paymentProvider',
                     'subscriptionVersion', 'lastPaymentAt', 'ownerId'
                   ]))
            // Scoped center admin may update non-billing fields (e.g. doctorCount).
            || (isCenterAdminForCenter(centerId)
                && !request.resource.data.diff(resource.data).affectedKeys().hasAny([
                     'subscriptionStatus', 'centerStatus',
                     'trialStart', 'trialEnds',
                     'nextBillingDate', 'subscriptionStart', 'subscriptionEnd',
                     'currentPlan', 'billingCycle', 'paymentProvider',
                     'subscriptionVersion', 'lastPaymentAt', 'ownerId'
                   ])));


      // ── medical_centers/{centerId}/members/{uid} ───────────────────────
      //
      // Authority model (Phase 4 hardening):
      //   All write authority derives from isCenterAdminMember(centerId), which
      //   reads the member doc directly and cannot be spoofed by editing
      //   users/{uid}.centerRole (isCenterAdminForCenter was the old — weaker — check).
      //
      // Self-protection:  admins cannot modify their own member record.
      // Target protection: center_admin records cannot be modified by client writes.
      // Promotion block:  role cannot be changed to 'center_admin' from the client.
      // Field restriction: updates are limited to operational fields.
      //
      match /members/{memberId} {
        // READ: center members, owner, admin, or own record.
        // resource.data.uid == request.auth.uid covers the collectionGroup
        // startup query (first-login chicken-and-egg before isCenterMember resolves).
        allow read: if isSignedIn()
          && (isCenterMember(centerId)
              || isCenterOwner(centerId)
              || isAdmin()
              || resource.data.uid == request.auth.uid);

        // ── CREATE path 1: Founder self-membership ─────────────────────
        // Allowed only while the parent center doc does not yet exist.
        // !exists() guard permanently closes this path on committed centers.
        // Both doctors and diagnostic providers may create their own center.
        allow create: if (isDoctor() || isDiagnosticProvider())
          && request.resource.data.uid == request.auth.uid
          && request.resource.data.role == 'center_admin'
          && request.resource.data.isActive == true
          && !exists(/databases/$(database)/documents/medical_centers/$(centerId));

        // ── CREATE path 2: Staff invite + doctor join approval ─────────
        // Requires isCenterAdminMember (member-doc authority — not users-doc).
        // Cannot create a new center_admin via this path.
        // accountLifecycle sub-object is Cloud Functions only.
        allow create: if !touchesLifecycle()
          && (isCenterOwner(centerId) || isCenterAdminMember(centerId))
          && request.resource.data.get('role', '') != 'center_admin';

        // ── UPDATE path 1: Scoped center admin ─────────────────────────
        // Authority: isCenterAdminMember reads member doc directly.
        //   Cannot be spoofed by editing users/{uid}.centerRole.
        // Self-protection:  resource.data.uid != caller uid.
        // Target protection: cannot update center_admin records.
        // Promotion block:   cannot set role to center_admin.
        // Field restriction: only operational fields may change.
        allow update: if !touchesLifecycle()
          && isCenterAdminMember(centerId)
          && resource.data.get('uid', '') != request.auth.uid
          && resource.data.get('role', '') != 'center_admin'
          && request.resource.data.get('role', '') != 'center_admin'
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
               'role', 'permissions', 'isActive', 'displayName',
               'updatedAt', 'updatedBy',
               'reactivatedBy', 'reactivatedAt', 'deactivatedBy', 'deactivatedAt'
             ]);

        // ── UPDATE path 2: Center owner or global admin ─────────────────
        // Unrestricted — covers emergency fixes, migration scripts, and
        // operations that span field restrictions (e.g. ownerId reassignment).
        allow update: if !touchesLifecycle()
          && (isCenterOwner(centerId) || isAdmin());

        // ── DELETE ──────────────────────────────────────────────────────
        // Center admin may cancel invitations and remove staff.
        // Self-protection: admin cannot delete own member doc.
        // Target protection: admin cannot delete other center_admin docs.
        allow delete: if isCenterOwner(centerId)
          || isAdmin()
          || (isCenterAdminMember(centerId)
              && resource.data.get('uid', '') != request.auth.uid
              && resource.data.get('role', '') != 'center_admin');
      }


      // ── medical_centers/{centerId}/clinical_templates/{templateId} ────────
      //
      // Center-owned reusable clinical request templates (Phase 2B).
      // 'single' templates have 1 item; 'bundle' templates have 2–10 items.
      //
      // READ:   any approved center member (doctor, nurse, receptionist).
      // CREATE: center admin only. Enforces on creation:
      //           - centerId matches path segment (no cross-center writes)
      //           - isActive must be true
      //           - createdBy must be the caller's uid
      //           - version must be 1
      //           - items must be non-empty and capped at 10
      // UPDATE: center admin only. Immutable after creation:
      //           centerId, createdBy, createdAt, version.
      //         Archive via isActive=false; restore via isActive=true.
      // DELETE: forbidden — archive only.
      //
      match /clinical_templates/{templateId} {
        allow read: if isSignedIn() && isCenterMember(centerId);

        allow create: if isSignedIn()
          && isCenterAdminMember(centerId)
          && request.resource.data.centerId == centerId
          && request.resource.data.isActive == true
          && request.resource.data.createdBy == request.auth.uid
          && request.resource.data.version == 1
          && request.resource.data.items.size() > 0
          && request.resource.data.items.size() <= 10;

        allow update: if isSignedIn()
          && isCenterAdminMember(centerId)
          && request.resource.data.centerId == resource.data.centerId
          && request.resource.data.createdBy == resource.data.createdBy
          && request.resource.data.createdAt == resource.data.createdAt
          && request.resource.data.version == resource.data.version;

        // No delete — archive via isActive = false (update path above)
      }

      // ── medical_centers/{centerId}/clinical_custom_categories/{categoryId} ─
      //
      // Center-owned custom service categories (Phase 2C).
      //
      // READ:   any approved center member.
      // CREATE: center admin only. Enforces on creation:
      //           - centerId matches path segment (no cross-center writes)
      //           - isActive must be true
      //           - createdBy must be the caller's uid
      // UPDATE: center admin only. Immutable: centerId, createdBy, createdAt.
      //         Archive via isActive=false; restore via isActive=true.
      // DELETE: forbidden — archive only.
      //
      match /clinical_custom_categories/{categoryId} {
        allow read: if isSignedIn() && isCenterMember(centerId);

        allow create: if isSignedIn()
          && isCenterAdminMember(centerId)
          && request.resource.data.centerId == centerId
          && request.resource.data.isActive == true
          && request.resource.data.createdBy == request.auth.uid;

        allow update: if isSignedIn()
          && isCenterAdminMember(centerId)
          && request.resource.data.centerId == resource.data.centerId
          && request.resource.data.createdBy == resource.data.createdBy
          && request.resource.data.createdAt == resource.data.createdAt;

        // No delete — archive via isActive = false (update path above)
      }

      // ── medical_centers/{centerId}/clinical_custom_types/{typeId} ──────────
      //
      // Center-owned custom tests / sub-types (Phase 2C).
      // categoryId accepts both custom category IDs and system category strings.
      //
      // READ:   any approved center member.
      // CREATE: center admin only. Enforces on creation:
      //           - centerId matches path segment (no cross-center writes)
      //           - isActive must be true
      //           - createdBy must be the caller's uid
      // UPDATE: center admin only. Immutable: centerId, categoryId, createdBy, createdAt.
      //         Archive via isActive=false; restore via isActive=true.
      // DELETE: forbidden — archive only.
      //
      match /clinical_custom_types/{typeId} {
        allow read: if isSignedIn() && isCenterMember(centerId);

        allow create: if isSignedIn()
          && isCenterAdminMember(centerId)
          && request.resource.data.centerId == centerId
          && request.resource.data.isActive == true
          && request.resource.data.createdBy == request.auth.uid;

        allow update: if isSignedIn()
          && isCenterAdminMember(centerId)
          && request.resource.data.centerId == resource.data.centerId
          && request.resource.data.categoryId == resource.data.categoryId
          && request.resource.data.createdBy == resource.data.createdBy
          && request.resource.data.createdAt == resource.data.createdAt;

        // No delete — archive via isActive = false (update path above)
      }

      // ── medical_centers/{centerId}/visit_templates/{templateId} ──────────
      //
      // Center-owned after-visit note templates. Selecting inserts content
      // into the clinical note editor; doctors edit freely before saving.
      //
      // READ:   any signed-in center member (doctor, nurse, receptionist, manager).
      // CREATE: center admin only. centerId must match path; isActive must be true;
      //         createdByUid must equal the caller's uid.
      // UPDATE: center admin only. Immutable: centerId, createdByUid, createdAt.
      //         Archive: isActive=false + isArchived=true. Restore: inverse.
      // DELETE: forbidden — archive only (soft-delete).
      //
      match /visit_templates/{templateId} {
        allow read: if isSignedIn() && isCenterMember(centerId);

        allow create: if isSignedIn()
          && isCenterAdminMember(centerId)
          && request.resource.data.centerId == centerId
          && request.resource.data.isActive == true
          && request.resource.data.createdByUid == request.auth.uid;

        allow update: if isSignedIn()
          && isCenterAdminMember(centerId)
          && request.resource.data.centerId == resource.data.centerId
          && request.resource.data.createdByUid == resource.data.createdByUid
          && request.resource.data.createdAt == resource.data.createdAt;

        allow delete: if false;
      }
    }


    // ───────────────────────────────────────────────────────────────────────
    // account_deletion_log/{eventId}
    //
    // Compliance audit trail — 7-year retention.
    // Written exclusively by lifecycle Cloud Functions via admin SDK.
    // No client read or write permitted.
    // ───────────────────────────────────────────────────────────────────────

    match /account_deletion_log/{eventId} {
      allow read, write: if false;
    }


    // ───────────────────────────────────────────────────────────────────────
    // account_deletion_requests/{requestId}
    //
    // Analytics and support layer — 3-year retention, aggregate-and-purge after 3 years.
    // Written exclusively by lifecycle Cloud Functions via admin SDK.
    // No client read or write permitted.
    // ───────────────────────────────────────────────────────────────────────

    match /account_deletion_requests/{requestId} {
      allow read, write: if false;
    }


    // ───────────────────────────────────────────────────────────────────────
    // payments/{paymentId}
    //
    // Read:   own payment (userId match) or center owner or admin
    // Create: authenticated user for their own payment (initiating subscription)
    // Update: admin always; client may submit (declared→under_review) or renew (completed→declared)
    // ───────────────────────────────────────────────────────────────────────

    match /payments/{paymentId} {
      allow read: if isSignedIn()
        && (resource == null
            || resource.data.uid == request.auth.uid
            || resource.data.userId == request.auth.uid
            || (resource.data.get('centerId', null) is string
                && resource.data.get('centerId', '').size() > 0
                && (isCenterOwner(resource.data.get('centerId', ''))
                    || isCenterAdminMember(resource.data.get('centerId', ''))))
            || isAdmin());

      allow create: if isSignedIn()
        && (request.resource.data.userId == request.auth.uid
            || request.resource.data.uid == request.auth.uid);

      // Scoped client update: payment creator may submit (declared → under_review).
      // All other status transitions remain admin/server-only.
      allow update: if isAdmin()
        // Step 2: submit for review after declaring intent
        || (isSignedIn()
            && resource.data.uid == request.auth.uid
            && resource.data.status == 'declared'
            && request.resource.data.status == 'under_review'
            && request.resource.data.diff(resource.data).affectedKeys()
                 .hasOnly(['status', 'updatedAt']))
        // Renewal: center owner may re-initiate payment from a completed cycle.
        // The open payment doc (open_center_{centerId}) is reused across renewals.
        // .set(merge:true) on an existing doc evaluates as update in rules.
        // Target may be awaiting_transfer (new canonical) or declared (legacy);
        // activation still requires admin approval in both cases.
        || (isSignedIn()
            && (resource.data.uid == request.auth.uid
                || (resource.data.centerId is string
                    && resource.data.centerId.size() > 0
                    && isCenterOwner(resource.data.centerId)))
            && resource.data.status == 'completed'
            && request.resource.data.status in ['awaiting_transfer', 'declared']
            && request.resource.data.centerId == resource.data.centerId
            && request.resource.data.uid == request.auth.uid
            && request.resource.data.userId == request.auth.uid)
        // Confirm transfer: doctor marks awaiting_transfer payment as sent.
        // Only the original submitter may do this. hasOnly prevents writing
        // activation fields; actual activation still requires admin approval.
        || (isSignedIn()
            && resource.data.uid == request.auth.uid
            && resource.data.status == 'awaiting_transfer'
            && request.resource.data.status == 'under_review'
            && request.resource.data.diff(resource.data).affectedKeys()
                 .hasOnly(['status', 'submittedAt', 'updatedAt']))
        // Resubmit after rejection: original submitter or current center owner may
        // restart a rejected open payment doc. centerId is immutable; target may be
        // awaiting_transfer (new canonical) or declared (backward compat for legacy
        // clients). Activation still requires admin approval in both cases.
        || (isSignedIn()
            && (resource.data.uid == request.auth.uid
                || (resource.data.centerId is string
                    && resource.data.centerId.size() > 0
                    && isCenterOwner(resource.data.centerId)))
            && resource.data.status == 'rejected'
            && request.resource.data.status in ['awaiting_transfer', 'declared']
            && request.resource.data.centerId == resource.data.centerId
            && request.resource.data.uid == request.auth.uid);
    }


    // ───────────────────────────────────────────────────────────────────────
    // center_join_requests/{requestId}
    //
    // Doc ID pattern: '{centerId}_{doctorId}'
    // Read:   the requesting doctor, the center owner, or admin
    // Create: doctor only; doctorId must match caller; initial status must be 'pending'
    // Update: center owner or admin (to approve / reject)
    // ───────────────────────────────────────────────────────────────────────

    match /center_join_requests/{requestId} {
      allow read: if isSignedIn()
        && (resource.data.doctorId == request.auth.uid
            || isCenterOwner(resource.data.centerId)
            || isCenterAdminForCenter(resource.data.centerId)
            || isAdmin());

      allow create: if isDoctor()
        && request.resource.data.doctorId == request.auth.uid
        && request.resource.data.status == 'pending';

      allow update: if isCenterOwner(resource.data.centerId)
        || isCenterAdminForCenter(resource.data.centerId)
        || isAdmin();
    }


    // ───────────────────────────────────────────────────────────────────────
    // center_partnership_requests/{requestId}
    //
    // Diagnostic provider → medical center partnership requests.
    // Intentionally separate from center_join_requests so that the
    // center-membership side-effect on approval can never fire for a lab.
    //
    // Read:   the requesting provider, the center owner/admin, or admin
    // Create: diagnostic provider only; providerId must match caller; status must be 'pending'
    // Update: center owner/admin or admin (to approve / reject)
    // ───────────────────────────────────────────────────────────────────────

    match /center_partnership_requests/{requestId} {
      allow read: if isSignedIn()
        && (resource.data.providerId == request.auth.uid
            || isCenterOwner(resource.data.centerId)
            || isCenterAdminForCenter(resource.data.centerId)
            || isAdmin());

      allow create: if isSignedIn()
        && exists(/databases/$(database)/documents/diagnostic_providers/$(request.auth.uid))
        && request.resource.data.providerId == request.auth.uid
        && request.resource.data.status == 'pending';

      allow update: if isCenterOwner(resource.data.centerId)
        || isCenterAdminForCenter(resource.data.centerId)
        || isAdmin();
    }


    // ───────────────────────────────────────────────────────────────────────
    // national_ids/{nationalId}
    //
    // Doc ID = normalized national ID number (digits only, Arabic/Persian
    // numerals converted to ASCII). Used solely to prevent duplicate
    // registrations via an atomic read-then-write transaction.
    //
    // get:    any authenticated user — safe because:
    //           (a) the doc ID is the national ID number itself; you must
    //               already know the number to query it, so a random user
    //               cannot enumerate or discover other people's IDs.
    //           (b) the doc data is minimal: doctorId, status, createdAt —
    //               no PII beyond the ID the caller already supplied.
    //           Previously restricted to isDoctor() but this blocked
    //           diagnostic_provider users whose users/{uid}.role is not
    //           'doctor' — even though their doctors/{uid} draft exists.
    //           isSignedIn() is the correct gate for a uniqueness check.
    // list:   admin only — prevents enumeration of the full national_ids set.
    // Create: authenticated user; doctorId field must equal caller's uid.
    //         Both doctor and diagnostic_provider onboarding flows use this.
    // Update/Delete: admin only — locks are permanent after creation.
    //
    // Privacy note: doc ID is the raw national ID number. A future hardening
    // pass should replace it with SHA-256(nationalId + projectSalt).
    // ───────────────────────────────────────────────────────────────────────

    match /national_ids/{nationalId} {
      allow get:  if isSignedIn();
      allow list: if isAdmin();

      allow create: if isSignedIn()
        && request.resource.data.doctorId == request.auth.uid;

      allow update, delete: if isAdmin();
    }


    // ───────────────────────────────────────────────────────────────────────
    // shiftTemplates/{templateId}
    //
    // Doctor portal only. Each template belongs to one doctor (doctorId field).
    // ───────────────────────────────────────────────────────────────────────

    match /shiftTemplates/{templateId} {
      allow read: if isDoctor()
        && resource.data.doctorId == request.auth.uid;

      allow create: if isDoctor()
        && request.resource.data.doctorId == request.auth.uid;

      allow update, delete: if isDoctor()
        && resource.data.doctorId == request.auth.uid;
    }


    // ───────────────────────────────────────────────────────────────────────
    // External import collections  (admin read only)
    // Used by mydoctor_admin for the doctor import workflow.
    // ───────────────────────────────────────────────────────────────────────

    match /google_doctors/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /public_doctors/{doctorId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ── Public diagnostic provider profiles ───────────────────────────────────
    // Safe patient-facing projection of diagnostic_providers/{uid}.
    // Written exclusively by the syncPublicDiagnosticProvider Cloud Function
    // (or admin backfill). Only eligible providers (active + verified) appear here.
    // Read access is intentionally public — same pattern as public_doctors.
    match /public_diagnostic_providers/{providerId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /facebook_doctors/{id} {
      allow read: if isAdmin();
    }


    // ───────────────────────────────────────────────────────────────────────
    // Collection group: members
    //
    // Authorizes collectionGroup('members').where('uid', isEqualTo: uid)
    // queries fired on startup to resolve staff identity.
    // A user may only read member documents where uid == their own auth uid.
    // Write access is not granted here — governed by the nested rule only.
    // ───────────────────────────────────────────────────────────────────────

    match /{path=**}/members/{memberId} {
      allow read: if isSignedIn()
        && resource.data.uid == request.auth.uid;
    }

    // Collection group: lab_members
    //
    // Authorizes collectionGroup('lab_members').where('uid', isEqualTo: uid)
    // queries fired on startup by labScopeProvider to resolve lab staff identity.
    // Separate from 'members' — no overlap with center staff collectionGroup queries.
    // A user may only read lab_members documents where uid == their own auth uid.
    // Write access is governed by the nested rule inside diagnostic_providers only.
    // ───────────────────────────────────────────────────────────────────────

    match /{path=**}/lab_members/{memberId} {
      allow read: if isSignedIn()
        && resource.data.uid == request.auth.uid;
    }


    // ───────────────────────────────────────────────────────────────────────
    // Clinical Requests
    //
    // Doctors create requests scoped to their appointment.
    // Staff (nurse/technician/receptionist) read and update requests
    // scoped to their center only.
    // Center admins have full read/write over their center.
    // Patient read: own released results only.
    // ───────────────────────────────────────────────────────────────────────

    match /clinical_requests/{requestId} {
      // Shared helper: caller belongs to the request's center
      function isRequestCenterMember() {
        return isCenterMember(resource.data.centerId);
      }

      // Doctors may create a request for their own appointment at their center.
      // Lab walk-in path: lab reception creates orders for physically-present patients.
      // Walk-in orders set source='walkin', requestDestination='partner',
      // partnerStatus='checkedIn', and centerId=labId (the lab refers to itself).
      // Lab scheduled path: lab reception pre-books a future appointment.
      // Scheduled orders set source='scheduled', partnerStatus='scheduled', slotId required.
      allow create: if isSignedIn() && (
        (request.resource.data.doctorId == request.auth.uid
          && isCenterMember(request.resource.data.centerId))
        ||
        (request.resource.data.get('source', '') == 'walkin'
          && request.resource.data.get('requestDestination', '') == 'partner'
          && request.resource.data.get('partnerStatus', '') == 'checkedIn'
          && (isLabMember(request.resource.data.get('partnerProviderId', ''))
              || request.auth.uid == request.resource.data.get('partnerProviderId', '')))
        ||
        (request.resource.data.get('source', '') == 'scheduled'
          && request.resource.data.get('requestDestination', '') == 'partner'
          && request.resource.data.get('partnerStatus', '') == 'scheduled'
          && request.resource.data.get('slotId', '') != ''
          && (isLabMember(request.resource.data.get('partnerProviderId', ''))
              || request.auth.uid == request.resource.data.get('partnerProviderId', '')))
        ||
        // Patient self-books a scheduled lab/imaging appointment.
        // Starts as pendingApproval — lab reception must approve before it becomes scheduled.
        // patientId must equal auth.uid — patient can only book for themselves (or family,
        // but the account holder's uid is always the identity anchor).
        (request.resource.data.get('source', '') == 'scheduled'
          && request.resource.data.get('requestDestination', '') == 'partner'
          && request.resource.data.get('partnerStatus', '') == 'pendingApproval'
          && request.resource.data.get('slotId', '') != ''
          && request.resource.data.get('createdByRole', '') == 'patient'
          && request.resource.data.get('patientId', '') == request.auth.uid)
      );

      // Staff and admins may read any request in their center
      allow read: if isSignedIn() && isRequestCenterMember();

      // Doctors may read requests they created (by doctorId)
      allow read: if isSignedIn()
        && resource.data.doctorId == request.auth.uid;

      // Patient reads own released results only.
      // Query MUST constrain patientReleaseStatus == 'released'.
      allow read: if isSignedIn()
        && resource.data.patientId == request.auth.uid
        && resource.data.patientReleaseStatus == 'released';

      // Patient reads own self-booked scheduled requests (upcoming appointments).
      // Strictly bounded: only patient-created bookings with source='scheduled'.
      // Doctor-referred requests remain invisible until explicitly released.
      // Query MUST include all three constraints so Firestore can evaluate this
      // rule without resource.data lookups on unfiltered fields.
      allow read: if isSignedIn()
        && resource.data.patientId == request.auth.uid
        && resource.data.get('createdByRole', '') == 'patient'
        && resource.data.get('source', '') == 'scheduled';

      // Patient cancels their own pending or approved lab/imaging booking.
      // Only applies to patient-created scheduled requests in cancellable states.
      // Slot release (slot_locks deletion) is done in the same client batch.
      allow update: if isSignedIn()
        && request.auth.uid == resource.data.patientId
        && resource.data.get('source', '') == 'scheduled'
        && resource.data.get('createdByRole', '') == 'patient'
        && resource.data.get('partnerStatus', '') in ['pendingApproval', 'scheduled']
        && request.resource.data.get('partnerStatus', '') == 'cancelled'
        && request.resource.data.diff(resource.data).affectedKeys()
             .hasOnly(['partnerStatus', 'status', 'cancelledAt', 'updatedAt']);

      // Staff update: allowed fields are status, resultNote, resultItems,
      // completedByUid, completedByName, completedAt, completedDateKey,
      // claimedAt, cancelledAt, updatedAt
      allow update: if isSignedIn()
        && isRequestCenterMember()
        && request.resource.data.diff(resource.data).affectedKeys()
             .hasOnly(['status', 'resultNote', 'resultItems',
                       'completedByUid', 'completedByName',
                       'completedAt', 'completedDateKey', 'updatedAt',
                       'claimedAt', 'cancelledAt']);

      // Center admins may cancel (full update) or delete requests
      allow update: if isSignedIn()
        && isCenterAdminMember(resource.data.centerId);

      // Attachment counter update: ±1 only.
      // The batch write that creates or soft-deletes an attachment document
      // also updates attachmentCount on the parent. hasOnly prevents any
      // other field from being changed in the same batch operation, and the
      // arithmetic constraint prevents arbitrary counter manipulation.
      allow update: if isSignedIn()
        && isRequestCenterMember()
        && request.resource.data.diff(resource.data).affectedKeys()
             .hasOnly(['attachmentCount', 'updatedAt'])
        && (request.resource.data.attachmentCount == resource.data.attachmentCount + 1
            || request.resource.data.attachmentCount == resource.data.attachmentCount - 1);

      // Lab member attachment counter ±1 (mirrors center-member rule above).
      // partnerProviderId on walk-in orders is the labId — no get() needed.
      // Owner case: lab owner's UID == labId (diagnostic_provider doc ID) — no lab_members doc exists for owner.
      allow update: if isSignedIn()
        && (isLabMember(resource.data.get('partnerProviderId', ''))
            || request.auth.uid == resource.data.get('partnerProviderId', ''))
        && request.resource.data.diff(resource.data).affectedKeys()
             .hasOnly(['attachmentCount', 'updatedAt'])
        && (request.resource.data.attachmentCount == resource.data.attachmentCount + 1
            || request.resource.data.attachmentCount == resource.data.attachmentCount - 1);

      allow delete: if isSignedIn()
        && isCenterAdminMember(resource.data.centerId);

      // Doctor releases results to patient: own requests only, completed+unreleased,
      // release fields only — no clinical, scheduling, or operational field may change.
      allow update: if isSignedIn()
        && resource.data.doctorId == request.auth.uid
        && canReleaseClinicalResults(resource.data.centerId)
        && resource.data.status == 'completed'
        && resource.data.get('patientReleaseStatus', 'unreleased') == 'unreleased'
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
             'patientReleaseStatus', 'releasedAt', 'releasedByUid',
             'releasedByName', 'releasedByRole', 'doctorNote',
             'releaseResultNote', 'updatedAt'
           ]);

      // Lab releases walk-in / scheduled results directly to patient.
      // Only applies when doctorId is empty (no referring doctor on the order).
      // Doctor-referred partner requests must go through the doctor release path above.
      allow update: if isSignedIn()
        && resource.data.get('requestDestination', '') == 'partner'
        && resource.data.get('source', '') in ['walkin', 'scheduled']
        && resource.data.get('doctorId', '') == ''
        && (isLabMember(resource.data.get('partnerProviderId', ''))
            || request.auth.uid == resource.data.get('partnerProviderId', ''))
        && resource.data.status == 'completed'
        && resource.data.get('patientReleaseStatus', 'unreleased') == 'unreleased'
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
             'patientReleaseStatus', 'releasedAt', 'releasedByUid',
             'releasedByName', 'releasedByRole', 'releaseResultNote', 'updatedAt'
           ]);

      // Diagnostic provider reads partner requests addressed to them.
      // partnerProviderId == auth.uid gates the query so only the intended
      // recipient can read their own incoming requests.
      allow read: if isSignedIn()
        && resource.data.get('requestDestination', '') == 'partner'
        && resource.data.get('partnerProviderId', '') == request.auth.uid;

      // Lab members (non-owner staff) can read partner requests for their lab.
      // isLabMember() performs a cross-document get() — the query must be scoped
      // by partnerProviderId to bound the evaluated document set.
      allow read: if isSignedIn()
        && resource.data.get('requestDestination', '') == 'partner'
        && isLabMember(resource.data.get('partnerProviderId', ''));

      // Diagnostic provider acknowledges receipt (sent → received).
      // Only the four audit fields may change; no clinical or status fields.
      allow update: if isSignedIn()
        && resource.data.get('requestDestination', '') == 'partner'
        && resource.data.get('partnerProviderId', '') == request.auth.uid
        && resource.data.get('partnerStatus', '') == 'sent'
        && request.resource.data.get('partnerStatus', '') == 'received'
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
             'partnerStatus', 'partnerReceivedAt', 'partnerReceivedByUid', 'updatedAt'
           ]);

      // Diagnostic provider checks in patient (received → checkedIn).
      // Payment fields are optional — reception may capture payment at the same
      // time as check-in or skip it. hasOnly is a ceiling, not a floor.
      allow update: if isSignedIn()
        && resource.data.get('requestDestination', '') == 'partner'
        && resource.data.get('partnerProviderId', '') == request.auth.uid
        && resource.data.get('partnerStatus', '') == 'received'
        && request.resource.data.get('partnerStatus', '') == 'checkedIn'
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
             'partnerStatus', 'partnerCheckedInAt', 'partnerCheckedInByUid',
             'partnerCheckedInByName',
             'paymentStatus', 'paymentStatusUpdatedAt', 'paymentStatusUpdatedByUid',
             'paymentStatusUpdatedByName', 'amountPaid', 'paymentMethod', 'receiptRef',
             'updatedAt'
           ]);

      // Scheduled appointment: patient arrives and is checked in (scheduled → checkedIn).
      // Same field ceiling as the received → checkedIn rule; starting state differs.
      allow update: if isSignedIn()
        && resource.data.get('requestDestination', '') == 'partner'
        && resource.data.get('partnerProviderId', '') == request.auth.uid
        && resource.data.get('partnerStatus', '') == 'scheduled'
        && request.resource.data.get('partnerStatus', '') == 'checkedIn'
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
             'partnerStatus', 'partnerCheckedInAt', 'partnerCheckedInByUid',
             'partnerCheckedInByName',
             'paymentStatus', 'paymentStatusUpdatedAt', 'paymentStatusUpdatedByUid',
             'paymentStatusUpdatedByName', 'amountPaid', 'paymentMethod', 'receiptRef',
             'updatedAt'
           ]);

      // Scheduled appointment: patient did not arrive (scheduled → noShow).
      allow update: if isSignedIn()
        && resource.data.get('requestDestination', '') == 'partner'
        && resource.data.get('partnerProviderId', '') == request.auth.uid
        && resource.data.get('partnerStatus', '') == 'scheduled'
        && request.resource.data.get('partnerStatus', '') == 'noShow'
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
             'partnerStatus', 'partnerNoShowAt', 'partnerNoShowByUid',
             'partnerNoShowByName', 'updatedAt'
           ]);

      // Scheduled appointment: reception cancels (scheduled → cancelled).
      allow update: if isSignedIn()
        && resource.data.get('requestDestination', '') == 'partner'
        && resource.data.get('partnerProviderId', '') == request.auth.uid
        && resource.data.get('partnerStatus', '') == 'scheduled'
        && request.resource.data.get('partnerStatus', '') == 'cancelled'
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
             'partnerStatus', 'partnerCancelledAt', 'partnerCancelledByUid',
             'partnerCancelledByName', 'partnerCancelReason', 'partnerCancelNotes',
             'updatedAt'
           ]);

      // Pending approval → scheduled: lab owner approves a future appointment.
      allow update: if isSignedIn()
        && resource.data.get('requestDestination', '') == 'partner'
        && resource.data.get('partnerProviderId', '') == request.auth.uid
        && resource.data.get('partnerStatus', '') == 'pendingApproval'
        && request.resource.data.get('partnerStatus', '') == 'scheduled'
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
             'partnerStatus', 'partnerApprovedAt', 'partnerApprovedByUid',
             'partnerApprovedByName', 'updatedAt'
           ]);

      // Pending approval → cancelled: lab owner rejects a future appointment.
      allow update: if isSignedIn()
        && resource.data.get('requestDestination', '') == 'partner'
        && resource.data.get('partnerProviderId', '') == request.auth.uid
        && resource.data.get('partnerStatus', '') == 'pendingApproval'
        && request.resource.data.get('partnerStatus', '') == 'cancelled'
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
             'partnerStatus', 'partnerCancelledAt', 'partnerCancelledByUid',
             'partnerCancelledByName', 'partnerCancelReason', 'partnerCancelNotes',
             'updatedAt'
           ]);

      // Lab technician starts processing a checked-in partner request (pending → in_progress).
      allow update: if isSignedIn()
        && resource.data.get('requestDestination', '') == 'partner'
        && (isLabMember(resource.data.get('partnerProviderId', ''))
            || request.auth.uid == resource.data.get('partnerProviderId', ''))
        && resource.data.get('partnerStatus', '') == 'checkedIn'
        && resource.data.get('status', '') == 'pending'
        && request.resource.data.get('status', '') == 'in_progress'
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
             'status', 'claimedAt', 'updatedAt'
           ]);

      // Lab technician completes processing and records results (in_progress → completed).
      allow update: if isSignedIn()
        && resource.data.get('requestDestination', '') == 'partner'
        && (isLabMember(resource.data.get('partnerProviderId', ''))
            || request.auth.uid == resource.data.get('partnerProviderId', ''))
        && resource.data.get('partnerStatus', '') == 'checkedIn'
        && resource.data.get('status', '') == 'in_progress'
        && request.resource.data.get('status', '') == 'completed'
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
             'status', 'resultNote', 'resultItems',
             'completedAt', 'completedDateKey',
             'completedByUid', 'completedByName', 'updatedAt'
           ]);

      // Diagnostic provider captures payment on an existing partner request
      // (unpaid → paid). Covers: late payment after check-in, correction.
      // partnerStatus must not change — only financial fields.
      allow update: if isSignedIn()
        && resource.data.get('requestDestination', '') == 'partner'
        && resource.data.get('partnerProviderId', '') == request.auth.uid
        && resource.data.get('paymentStatus', 'unpaid') == 'unpaid'
        && request.resource.data.get('paymentStatus', '') == 'paid'
        && request.resource.data.get('paymentStatusUpdatedByUid', '') == request.auth.uid
        && request.resource.data.get('amountPaid', 0) > 0
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
             'paymentStatus', 'paymentStatusUpdatedAt', 'paymentStatusUpdatedByUid',
             'paymentStatusUpdatedByName', 'amountPaid', 'paymentMethod', 'receiptRef',
             'updatedAt'
           ]);

      // ── clinical_requests/{requestId}/attachments/{attachmentId} ──────────
      //
      // Clinical file attachments: PDF, images, DICOM.
      //
      // READ path 1 — center member: isCenterMember(resource.data.centerId).
      //   Requires the query to constrain centerId (staff board queries do this).
      // READ path 2 — request's doctor: get(parent).doctorId == auth.uid.
      //   No resource.data dependency — works for cross-center historical reads
      //   when the doctor is no longer a member of the request's center.
      //   These are TWO SEPARATE allow read rules — NOT a single || — so
      //   Firestore evaluates each independently and does not reject the list
      //   query due to the unconstrained centerId in path 1.
      //
      // CREATE: any center member — with field constraints:
      //           requestId must match the parent doc ID (no cross-doc write)
      //           patientVisible must be false on creation (never auto-release)
      //           isDeleted must be false on creation
      //           uploadedByUid must be the caller's uid
      //
      // UPDATE path 1 — Doctor release (Phase 2B):
      //           Only a doctor may flip patientVisible and write release audit fields.
      //           canReleaseClinicalResults() enforces doctor-only authority.
      //
      // UPDATE path 2 — Soft-delete:
      //           Only isDeleted may be written; must be set to true (no undelete).
      //           Either a center_admin OR the original uploader (if not yet released)
      //           may soft-delete.  A released attachment (patientVisible=true) is
      //           protected from deletion by non-admins.
      //
      // DELETE: never — physical deletion is reserved for a future Cloud Function
      //         purge job that runs after the soft-delete retention window expires.
      //
      match /attachments/{attachmentId} {
        // READ path 1 — Center members: uses resource.data.centerId.
        // Requires the caller's query to constrain centerId so Firestore can
        // evaluate this per-document rule without rejecting the list query.
        // Staff board queries always include centerId in their where() clauses.
        allow read: if isSignedIn()
          && isCenterMember(resource.data.centerId);

        // READ path 2 — Request's owning doctor: pure get() — zero resource.data
        // references, so Firestore evaluates it globally for the subcollection
        // without requiring a centerId/doctorId where() constraint on the query.
        // Allows cross-center reads when the doctor is no longer a member of the
        // center where the request was created (e.g. historical appointments).
        allow read: if isSignedIn()
          && get(/databases/$(database)/documents/clinical_requests/$(requestId)).data.doctorId == request.auth.uid;

        // READ path 3 — Patient reads own released visible attachments.
        // Verifies patientId ownership via parent document (get() call).
        // Only attachments explicitly marked patientVisible=true and not soft-deleted.
        allow read: if isSignedIn()
          && get(/databases/$(database)/documents/clinical_requests/$(requestId))
               .data.patientId == request.auth.uid
          && resource.data.patientVisible == true
          && resource.data.isDeleted == false;

        // READ path 4 — Lab member reads attachments on their lab's orders.
        // Uses labProviderForRequest() instead of resource.data.centerId so this rule
        // has zero resource.data dependencies.  Without this, Firestore rejects the
        // doctor's unconstrained list query (streamAttachments) even though READ path 2
        // independently grants access — Firestore may refuse any query where ANY allow
        // rule references resource.data without a matching where() constraint.
        // Owner case: lab owner's UID == partnerProviderId — no lab_members doc exists.
        allow read: if isSignedIn()
          && labProviderForRequest(requestId) != ''
          && (isLabMember(labProviderForRequest(requestId))
              || request.auth.uid == labProviderForRequest(requestId));

        allow create: if isSignedIn()
          && isCenterMember(request.resource.data.centerId)
          && request.resource.data.requestId == requestId
          && request.resource.data.patientVisible == false
          && request.resource.data.isDeleted == false
          && request.resource.data.uploadedByUid == request.auth.uid;

        // CREATE path 2 — Lab reception uploads paper referral for a walk-in order.
        // centerId on lab walk-in attachments is the labId so isLabMember() resolves
        // directly without a get() call.
        // Owner case: lab owner's UID == labId — no lab_members doc exists for owner.
        allow create: if isSignedIn()
          && (isLabMember(request.resource.data.centerId)
              || request.auth.uid == request.resource.data.centerId)
          && request.resource.data.requestId == requestId
          && request.resource.data.patientVisible == false
          && request.resource.data.isDeleted == false
          && request.resource.data.uploadedByUid == request.auth.uid;

        // Doctor releases attachment to patient.
        // Uses get(parent).doctorId — cross-center safe: works even when the doctor
        // is no longer a member of the center where the request was created.
        // Only patientVisible changes on attachment docs; audit fields go on parent.
        allow update: if isSignedIn()
          && canReleaseClinicalResults(resource.data.centerId)
          && get(/databases/$(database)/documents/clinical_requests/$(requestId)).data.doctorId
               == request.auth.uid
          && request.resource.data.diff(resource.data).affectedKeys()
               .hasOnly(['patientVisible']);

        // Lab releases walk-in / scheduled attachment to patient (no referring doctor).
        // labProviderForRequest() reads the parent request's partnerProviderId; the
        // subsequent get() calls to the same document path are cached by the rules engine.
        allow update: if isSignedIn()
          && labProviderForRequest(requestId) != ''
          && (isLabMember(labProviderForRequest(requestId))
              || request.auth.uid == labProviderForRequest(requestId))
          && get(/databases/$(database)/documents/clinical_requests/$(requestId)).data
               .get('source', '') in ['walkin', 'scheduled']
          && get(/databases/$(database)/documents/clinical_requests/$(requestId)).data
               .get('doctorId', '') == ''
          && request.resource.data.diff(resource.data).affectedKeys()
               .hasOnly(['patientVisible']);

        // Soft-delete: only isDeleted may change; must go true (not undelete).
        allow update: if isSignedIn()
          && isCenterMember(resource.data.centerId)
          && request.resource.data.diff(resource.data).affectedKeys()
               .hasOnly(['isDeleted'])
          && request.resource.data.isDeleted == true
          && (isCenterAdminMember(resource.data.centerId)
              || (resource.data.uploadedByUid == request.auth.uid
                  && resource.data.patientVisible == false));

        allow delete: if false;
      }
    }

    // ───────────────────────────────────────────────────────────────────────
    // diagnostic_providers/{uid}
    //
    // Lab/imaging providers registered through the doctor portal onboarding flow.
    // Provider kind: 'laboratory' | 'imaging' (stored in providerKind + serviceGroup).
    //
    // Read:   own doc, admin only.
    //         Public discovery (if needed) uses a future public_providers projection.
    // Create: provider self-registration during onboarding submit (uid must match).
    //         Same transaction writes users/{uid}.role = 'diagnostic_provider'.
    // Update: provider may update own profile fields;
    //         admin-controlled fields (status, isVerified, isActive, trial fields)
    //         are protected and require admin or Cloud Functions to change.
    // Delete: admin only.
    // ───────────────────────────────────────────────────────────────────────

    match /diagnostic_providers/{uid} {
      allow read: if isSignedIn()
        && (request.auth.uid == uid || isAdmin());

      allow create: if isSignedIn()
        && request.auth.uid == uid
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.status == 'pending'
        && request.resource.data.isActive == false
        && request.resource.data.isVerified == false;

      allow update: if isAdmin()
        || (isSignedIn()
            && request.auth.uid == uid
            && !request.resource.data.diff(resource.data).affectedKeys().hasAny([
                 'status', 'isVerified', 'isActive',
                 'subscriptionStatus', 'trialStart', 'trialEnds',
                 'verificationStatus', 'submittedAt'
               ]));

      allow delete: if isAdmin();

      // ── diagnostic_providers/{labId}/services/{serviceId} ─────────────────
      //
      // Lab/imaging service catalog. Provider-owned; immutable once archived.
      //
      // Read:   lab members/owner/admin see all services; public (unauthenticated)
      //         users can read only active + onlineBookingEnabled + non-archived.
      //         This allows QR-scan patients to browse the booking catalog without
      //         being signed in, while keeping internal/archived services private.
      // Create: lab admin or owner only. Cannot set isArchived: true on create.
      // Update: lab admin or owner; cannot un-archive (isArchived is one-way).
      // Delete: never — use isArchived: true for soft-delete.
      // ─────────────────────────────────────────────────────────────────────
      match /services/{serviceId} {
        allow read: if (resource.data.isActive == true
              && resource.data.onlineBookingEnabled == true
              && resource.data.get('isArchived', false) == false)
          || (isSignedIn()
              && (isLabMember(uid) || isLabOwner(uid) || isAdmin()));

        allow create: if isSignedIn()
          && (isLabOwner(uid) || isLabAdminMember(uid))
          && request.resource.data.providerId == uid
          && request.resource.data.get('isArchived', false) == false;

        allow update: if isSignedIn()
          && (isLabOwner(uid) || isLabAdminMember(uid))
          && !(resource.data.get('isArchived', false) == true
               && request.resource.data.get('isArchived', false) == false);

        allow delete: if false;
      }

      // ── diagnostic_providers/{labId}/lab_members/{memberId} ───────────────
      //
      // Lab staff membership subcollection.
      // Uses 'lab_members' (NOT 'members') to avoid collisionWith the center
      // collectionGroup('members') queries used by centerScopeProvider.
      //
      // Authority model mirrors medical_centers/.../members:
      //   All write authority derives from isLabAdminMember(labId) or isLabOwner.
      //   Self-protection: admins cannot modify their own lab_members doc.
      //   Target protection: lab_admin records cannot be updated by client writes.
      //   Promotion block: role cannot be changed to 'lab_admin' from the client.
      //   Field restriction: updates limited to operational fields only.
      //
      match /lab_members/{memberId} {
        // READ: lab members, owner, admin, or own record.
        // resource.data.uid == request.auth.uid covers the collectionGroup
        // startup query (first-login before isLabMember resolves).
        // NOTE: wildcard from parent match /diagnostic_providers/{uid} is 'uid',
        //       not 'labId' — all helper calls must use 'uid' here.
        allow read: if isSignedIn()
          && (isLabMember(uid)
              || isLabOwner(uid)
              || isAdmin()
              || resource.data.uid == request.auth.uid);

        // CREATE path 1: Lab admin founder self-membership.
        // Only allowed when the parent diagnostic_providers doc already exists
        // (lab owner completed onboarding).
        allow create: if isSignedIn()
          && request.resource.data.uid == request.auth.uid
          && request.resource.data.role == 'lab_admin'
          && request.resource.data.isActive == true
          && exists(/databases/$(database)/documents/diagnostic_providers/$(uid));

        // CREATE path 2: Lab admin or owner invites staff.
        // Cannot create a lab_admin member via this path.
        allow create: if (isLabOwner(uid) || isLabAdminMember(uid))
          && request.resource.data.get('role', '') != 'lab_admin';

        // UPDATE path 1: Scoped lab admin.
        // Self-protection: cannot update own record.
        // Target protection: cannot update lab_admin records.
        // Promotion block: cannot promote to lab_admin.
        // Field restriction: only operational fields.
        allow update: if isLabAdminMember(uid)
          && resource.data.get('uid', '') != request.auth.uid
          && resource.data.get('role', '') != 'lab_admin'
          && request.resource.data.get('role', '') != 'lab_admin'
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
               'role', 'permissions', 'isActive', 'displayName',
               'updatedAt', 'updatedBy',
               'reactivatedBy', 'reactivatedAt', 'deactivatedBy', 'deactivatedAt'
             ]);

        // UPDATE path 2: Lab owner or global admin — unrestricted.
        allow update: if isLabOwner(uid) || isAdmin();

        // DELETE: cancel invitations or remove staff.
        // Self-protection and target-protection apply.
        allow delete: if isLabOwner(uid)
          || isAdmin()
          || (isLabAdminMember(uid)
              && resource.data.get('uid', '') != request.auth.uid
              && resource.data.get('role', '') != 'lab_admin');
      }

      // ── diagnostic_providers/{labId}/clinical_templates/{templateId} ──────
      //
      // Lab/imaging reusable clinical request templates.
      // Same schema as medical_centers/.../clinical_templates.
      // centerId field stores labId as the scope identifier.
      //
      // Read:   any active lab member or owner can browse.
      // Create: lab admin or owner only. isActive must start true, version=1.
      // Update: lab admin or owner only. centerId/createdBy/createdAt/version
      //         are immutable and may not be touched after creation.
      // Delete: never — archive via isActive=false.
      // ──────────────────────────────────────────────────────────────────────
      match /clinical_templates/{templateId} {
        allow read: if isSignedIn()
          && (isLabMember(uid) || isLabOwner(uid) || isAdmin());

        allow create: if isSignedIn()
          && (isLabOwner(uid) || isLabAdminMember(uid))
          && request.resource.data.get('centerId', '') == uid
          && request.resource.data.get('isActive', false) == true
          && request.resource.data.get('version', 0) == 1;

        allow update: if isSignedIn()
          && (isLabOwner(uid) || isLabAdminMember(uid))
          && !request.resource.data.diff(resource.data).affectedKeys().hasAny([
               'centerId', 'createdBy', 'createdAt', 'version'
             ]);

        allow delete: if false;
      }
    }


    // ───────────────────────────────────────────────────────────────────────
    // Clinical Doctor Preferences
    //
    // Personal per-doctor document: favorites and recently used templates.
    // Strictly doctor-owned — only the owning doctor may read or write.
    // Document ID == doctorId == request.auth.uid.
    // ───────────────────────────────────────────────────────────────────────

    match /clinical_doctor_prefs/{doctorId} {
      allow read, write: if isSignedIn()
        && request.auth.uid == doctorId;
    }


    // ───────────────────────────────────────────────────────────────────────
    // Intentionally unmatched collections (implicit deny):
    //
    //   patients   — doctor portal uses 'users', not 'patients'. If this
    //                collection contains data, it is inaccessible from clients.
    //
    //   slotUsage  — purpose unclear; add an explicit rule before opening.
    //
    // OPEN SECURITY NOTE (blocker #9, not fixable via Firestore rules):
    //   zaincashCallback HTTP Cloud Function has no Firebase Auth check.
    //   It relies on ZainCash JWT verification only. Before going to
    //   production, add HMAC signature verification or an IP allowlist.
    // ───────────────────────────────────────────────────────────────────────

  }
}
