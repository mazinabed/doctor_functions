rules_version = '2';

// ═══════════════════════════════════════════════════════════════════════════
// TrustyDr Ecosystem — Firestore Security Rules
// Firebase project: doctorapp-7e8b3
//
// Surfaces covered:
//   • TrustyDr-pwa     — patient app (Flutter)
//   • doctor_portal    — doctor scheduling + center reception board (Flutter)
//   • mydoctor_admin   — global super-admin portal (Flutter)
//   • doctor_functions — Cloud Functions (Node.js / Admin SDK, bypasses rules)
//
// Role model:
//   "admin"  → users/{uid}.role == "admin"  (super-admin, set via set_admin_claim.js)
//   doctor   → doctors/{uid} document exists (uid == Firebase Auth UID)
//   patient  → authenticated user who is not a doctor
//   center staff → medical_centers/{centerId}/members/{uid} exists
//
// ═══════════════════════════════════════════════════════════════════════════

service cloud.firestore {
  match /databases/{database}/documents {


    // ───────────────────────────────────────────────────────────────────────
    // HELPER FUNCTIONS
    // ───────────────────────────────────────────────────────────────────────

    function isSignedIn() {
      return request.auth != null;
    }

    // Super-admin: users/{uid}.role == "admin"
    // Costs 1 document read per rule evaluation.
    function isAdmin() {
      return isSignedIn()
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin";
    }

    // Doctor: a doctors/{uid} document exists for the caller.
    // Costs 1 exists() check per rule evaluation.
    function isDoctor() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/doctors/$(request.auth.uid));
    }

    // Center staff: caller has a member doc in the given center.
    function isCenterMember(centerId) {
      return isSignedIn()
        && exists(/databases/$(database)/documents/medical_centers/$(centerId)/members/$(request.auth.uid));
    }

    // Center owner: caller's uid matches the center's ownerId field.
    function isCenterOwner(centerId) {
      return isSignedIn()
        && get(/databases/$(database)/documents/medical_centers/$(centerId)).data.ownerId == request.auth.uid;
    }

    // Center admin (unscoped): caller's users doc has centerRole == 'center_admin'.
    // Use for read-only rules where the specific center is embedded in each document
    // (e.g. doctors list query where centerId is in the document, not the rule path).
    // Costs 1 document read per rule evaluation.
    function isCenterAdmin() {
      return isSignedIn()
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('centerRole', '') == 'center_admin';
    }

    // Center admin scoped to a specific centerId.
    // Use wherever the target center is known from the rule path or resource data.
    // Prevents a center admin of one center from acting on another center.
    // Costs 1 document read per rule evaluation.
    function isCenterAdminForCenter(centerId) {
      let userDoc = get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
      return isSignedIn()
        && userDoc.get('centerRole', '') == 'center_admin'
        && userDoc.get('centerId', '') == centerId;
    }

    // Center admin via members subcollection — source of truth for billing access.
    // Reads medical_centers/{centerId}/members/{uid} directly; more reliable than
    // users.centerRole which may be absent for some doctor-owned center members.
    // centerId null-guard prevents path-building errors on documents without centerId.
    // exists() guard prevents null-access when the member doc is absent.
    function isCenterAdminMember(centerId) {
      return isSignedIn()
        && centerId is string
        && centerId.size() > 0
        && exists(/databases/$(database)/documents/medical_centers/$(centerId)/members/$(request.auth.uid))
        && get(/databases/$(database)/documents/medical_centers/$(centerId)/members/$(request.auth.uid)).data.get('role', '') == 'center_admin'
        && get(/databases/$(database)/documents/medical_centers/$(centerId)/members/$(request.auth.uid)).data.get('isActive', false) == true;
    }

    // Center owner OR scoped center admin may update exactly the three
    // doctor-to-center link fields (centerId, centerJoinStatus, centerJoinApprovedAt).
    // Approve flow: centerId is being set — verifies ownership/admin of the new center.
    // Remove flow:  centerId is being cleared — verifies ownership/admin of current center.
    function isDoctorCenterLinkUpdate() {
      let newCenterId = request.resource.data.get('centerId', null);
      let oldCenterId = resource.data.get('centerId', null);
      let targetId = newCenterId != null ? newCenterId : oldCenterId;
      return isSignedIn()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
             'centerId', 'centerJoinStatus', 'centerJoinApprovedAt'
           ])
        && targetId != null
        && (isCenterOwner(targetId) || isCenterAdminForCenter(targetId));
    }

    // Center staff may mark an appointment unpaid → paid.
    // All three audit fields must be co-written with paymentStatus; no other
    // fields may change. The caller must be a member of the appointment's center.
    function isPaymentStatusUpdate(centerId) {
      return isSignedIn()
        && isCenterMember(centerId)
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
             'paymentStatus', 'paymentStatusUpdatedAt',
             'paymentStatusUpdatedBy', 'updatedAt'
           ])
        && resource.data.paymentStatus == 'unpaid'
        && request.resource.data.paymentStatus == 'paid'
        && request.resource.data.paymentStatusUpdatedBy == request.auth.uid;
    }

    // Path B (reception/walk-in) may create as unpaid or pre-paid.
    // Pre-paid requires identity and method audit; patient app is always unpaid.
    function isValidCreationPayment() {
      return request.resource.data.paymentStatus == 'unpaid'
        || (request.resource.data.paymentStatus == 'paid'
            && request.resource.data.paymentStatusUpdatedBy == request.auth.uid
            && request.resource.data.get('paymentMethod', '') == 'front_desk_cash');
    }

    // Center is operationally active: now falls within trial, subscription,
    // or grace period window. Mirrors centerAccessProvider date-only logic.
    // Returns false (fail-closed) if all date fields are absent.
    function centerIsOperational(centerId) {
      let center = get(/databases/$(database)/documents/medical_centers/$(centerId));
      let now = request.time;
      let trialEnds = center.data.get('trialEnds', null);
      let subscriptionEnd = center.data.get('subscriptionEnd', null);
      let gracePeriodEnds = center.data.get('gracePeriodEnds', null);
      return (trialEnds != null && now < trialEnds)
        || (subscriptionEnd != null && now < subscriptionEnd)
        || (gracePeriodEnds != null && now < gracePeriodEnds);
    }

    // Fields on doctors/{uid} that only Cloud Functions / admin may write.
    // Doctors cannot self-escalate their subscription or verification status.
    //
    // Exception: the doctor may accept legal consent, which transitions
    // status from 'legalConsent' → 'onboarding'. This is the only permitted
    // client-side status write; all other status changes remain admin-only.
    function isLegalConsentTransition() {
      return resource.data.status == 'legalConsent'
        && request.resource.data.status == 'onboarding'
        && request.resource.data.get('legalAccepted', false) == true;
    }

    // Doctor submits completed onboarding for admin review.
    // Allowed ONLY when transitioning onboarding → pending and all privilege
    // flags are explicitly set to false (no self-escalation possible).
    function isOnboardingSubmitTransition() {
      return resource.data.status == 'onboarding'
        && request.resource.data.status == 'pending'
        && request.resource.data.get('submittedAt', null) != null
        && request.resource.data.isActive == false
        && request.resource.data.isVerified == false
        && request.resource.data.canBook == false
        && request.resource.data.canCall == false;
    }

    function touchesDoctorAdminFields() {
      return !isLegalConsentTransition()
        && !isOnboardingSubmitTransition()
        && request.resource.data.diff(resource.data).affectedKeys().hasAny([
          'isPaidUser', 'subscriptionStatus', 'subscriptionPlan',
          'nextBillingDate', 'trialStart', 'trialEnds',
          'isActive', 'isVerified', 'verificationStatus',
          'canBook', 'canCall', 'status'
        ]);
    }

    // Detects whether a write touches the accountLifecycle sub-object.
    // Used to block client-side lifecycle writes — only Cloud Functions (admin SDK)
    // may write accountLifecycle. Admin SDK bypasses rules entirely.
    //
    // For creates (resource == null): check if accountLifecycle appears in the
    // new document's keys. diff() requires a non-null resource so cannot be used.
    // For updates (resource != null): check if accountLifecycle is in the diff.
    function touchesLifecycle() {
      return resource == null
        ? request.resource.data.keys().hasAny(['accountLifecycle'])
        : request.resource.data.diff(resource.data).affectedKeys()
            .hasAny(['accountLifecycle']);
    }

    // Core identity fields on an appointment that must never change after creation.
    // patientHealthSnapshot is immutable — health context is fixed at booking time.
    function appointmentCoreUnchanged() {
      return !request.resource.data.diff(resource.data).affectedKeys().hasAny([
        'patientId', 'doctorId', 'centerId', 'source',
        'bookedByUserId', 'bookedByRole', 'appointmentAt',
        'dateKey', 'slotId', 'createdAt', 'patientHealthSnapshot'
      ]);
    }

    // Validates the embedded health snapshot written at booking time.
    //   null  → family/relative booking or missing profile — always allowed.
    //   map   → self-booking snapshot; must be schemaVersion 1 and must NOT
    //           include dateOfBirth (DOB is never stored in appointment documents).
    function validHealthSnapshot(snap) {
      return snap == null
        || (snap is map
            && snap.get('schemaVersion', 0) == 1
            && !snap.keys().hasAny(['dateOfBirth']));
    }


    // ───────────────────────────────────────────────────────────────────────
    // REFERENCE DATA  (public read — cities, provinces, specialties)
    // ───────────────────────────────────────────────────────────────────────

    match /specialties/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /provinces/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /cities/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ───────────────────────────────────────────────────────────────────────
    // public_daily_health_weather/{provinceKey}
    //
    // Environmental awareness data — cached province-level summaries written
    // once daily by the scheduleDailyHealthWeather Cloud Function (Admin SDK,
    // which bypasses these rules entirely).
    //
    // Read:  public — no auth required (environmental data, no PII).
    // Write: Admin SDK only in normal operation.
    //        isAdmin() guard allows super-admin manual override if needed
    //        (e.g., correcting a stale document without redeploying the function).
    //
    // No user data is stored in this collection.
    // ───────────────────────────────────────────────────────────────────────

    match /public_daily_health_weather/{provinceKey} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ───────────────────────────────────────────────────────────────────────
    // public_home_announcements/{id}
    //
    // General-awareness dashboard cards shown in the patient home screen.
    // Contains no PII — purely editorial content (clinic schedules, health
    // campaigns, system notices).
    //
    // Read:  public — no auth required.
    // Write: super-admin only (manual Firestore console or admin portal).
    //        Admin SDK Cloud Functions also bypass these rules if needed.
    // ───────────────────────────────────────────────────────────────────────

    match /public_home_announcements/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }


    // ───────────────────────────────────────────────────────────────────────
    // users/{uid}
    //
    // Read:   own doc, admin (patient_directory), or doctor (phone search)
    // Create: own doc only; cannot self-assign "admin" role
    // Update: own doc (cannot escalate to admin); admin unrestricted
    // ───────────────────────────────────────────────────────────────────────

    match /users/{uid} {
      allow read: if isSignedIn()
        && (request.auth.uid == uid
            || isAdmin()
            || isDoctor());

      allow create: if isSignedIn()
        && request.auth.uid == uid
        && (!request.resource.data.keys().hasAny(['role'])
            || request.resource.data.role != 'admin');

      // accountLifecycle is controlled exclusively by Cloud Functions (admin SDK).
      // No client path — including admin portal — may write this sub-object.
      allow update: if !touchesLifecycle()
        && (isAdmin()
            || (isSignedIn()
                && request.auth.uid == uid
                && (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['role'])
                    || request.resource.data.role != 'admin')));

      // ── users/{uid}/notifications ──────────────────────────────────────────
      // Appointment reminder notifications written by Cloud Functions (Admin SDK).
      // Patient reads own subcollection only.
      // Patient may flip isRead — no other field may be changed from the client.
      // create/delete are always false: only Cloud Functions write these docs.
      match /notifications/{notifId} {
        allow read:   if isSignedIn() && request.auth.uid == uid;
        allow update: if isSignedIn()
                      && request.auth.uid == uid
                      && request.resource.data.diff(resource.data)
                           .affectedKeys().hasOnly(['isRead', 'dismissed', 'dismissedAt']);
        allow create: if false;
        allow delete: if false;
      }

      // ── users/{uid}/fcmTokens ──────────────────────────────────────────────
      // FCM push tokens — one doc per device, managed by the patient app.
      // Cloud Functions use Admin SDK (bypass rules) for stale-token cleanup.
      // Patient may read/create/update/delete only their own token docs.
      match /fcmTokens/{tokenId} {
        allow read, write: if isSignedIn() && request.auth.uid == uid;
      }
    }


    // ───────────────────────────────────────────────────────────────────────
    // doctors/{uid}
    //
    // Read:   own doc, admin, or another verified doctor (portal use).
    //         Patients rely on public_doctors/{uid} — a safe projection that
    //         excludes phone, email, nationalId, license docs, and billing.
    //         Tightened from isSignedIn() to block patient-side direct reads.
    // Create: doctor self-registration (uid must match)
    // Update: doctor updates own profile fields; admin updates any field
    //         Protected fields (touchesDoctorAdminFields): only admin / Cloud Functions
    //
    // Subcollection: doctors/{uid}/reviews
    // ───────────────────────────────────────────────────────────────────────

    match /doctors/{uid} {
      // isCenterAdmin() allows non-doctor center managers to read doctor
      // profiles for center management (pending requests, approved doctors list).
      allow read: if isSignedIn()
        && (request.auth.uid == uid || isAdmin() || isDoctor() || isCenterAdmin());

      allow create: if isSignedIn()
        && request.auth.uid == uid;

      // accountLifecycle is controlled exclusively by Cloud Functions (admin SDK).
      allow update: if !touchesLifecycle()
        && (isAdmin()
            || (isSignedIn()
                && request.auth.uid == uid
                && !touchesDoctorAdminFields())
            // Center owner or scoped center admin may link/unlink a doctor during
            // the join-request approve and remove flows (ManageDoctors tab).
            || isDoctorCenterLinkUpdate());


      // ── doctors/{uid}/reviews ──────────────────────────────────────────
      // Patients (non-doctors) may create one review per visit.
      // Reviews are immutable after creation (update/delete = admin only).
      match /reviews/{reviewId} {
        allow read: if true;

        allow create: if isSignedIn()
          && !isDoctor()
          && request.resource.data.userId == request.auth.uid;

        allow update, delete: if isAdmin();
      }
    }


    // ───────────────────────────────────────────────────────────────────────
    // schedules/{scheduleId}
    //
    // Read:   published schedules (patient app) OR own schedules (doctor portal)
    // Create: doctor only; doctorId field must match caller's uid
    // Update: doctor who owns the schedule
    // Delete: owning doctor or admin
    // ───────────────────────────────────────────────────────────────────────

    match /schedules/{scheduleId} {
      // Published active schedules are publicly readable — guest availability browsing.
      // Unpublished and inactive schedules remain private.
      allow read: if (resource.data.status == 'published' && resource.data.isActive == true)
        || (isSignedIn() && (resource.data.doctorId == request.auth.uid || isAdmin()));

      allow create: if isDoctor()
        && request.resource.data.doctorId == request.auth.uid
        && centerIsOperational(request.resource.data.centerId);

      allow update: if isDoctor()
        && resource.data.doctorId == request.auth.uid
        && centerIsOperational(resource.data.centerId);

      allow delete: if (isDoctor() && resource.data.doctorId == request.auth.uid)
        || isAdmin();
    }


    // ───────────────────────────────────────────────────────────────────────
    // appointments/{appointmentId}
    //
    // CREATE — two paths:
    //   Path A: patient self-booking (patient app)
    //   Path B: center staff / doctor booking walk-in or follow-up (doctor portal)
    //
    // READ:  patient (own), doctor (own), center staff, admin
    //
    // UPDATE — three roles with different field permissions:
    //   Doctor   → any non-core field (status, visitStatus, paymentStatus, notes…)
    //   Center staff → visitStatus, paymentStatus, status, notes, timestamps
    //   Patient  → status:'cancelled' + cancelledAt only
    //   Admin    → unrestricted
    // ───────────────────────────────────────────────────────────────────────

    match /appointments/{appointmentId} {

      allow read: if isSignedIn()
        && (resource == null
            || resource.data.patientId == request.auth.uid
            || resource.data.doctorId == request.auth.uid
            || isCenterMember(resource.data.centerId)
            || isAdmin());

      // ── Path A: patient self-booking ──────────────────────────────────
      // patientHealthSnapshot may be null (missing profile) or a valid snapshot
      // map (self-booking with health data). dateOfBirth is always excluded.
      allow create: if isSignedIn()
        && request.resource.data.source == 'patient_app'
        && request.resource.data.patientId == request.auth.uid
        && request.resource.data.bookedByUserId == request.auth.uid
        && request.resource.data.bookedByRole == 'patient'
        && request.resource.data.status == 'pending'
        && request.resource.data.paymentStatus == 'unpaid'
        && request.resource.data.visitStatus == 'waiting'
        && centerIsOperational(request.resource.data.centerId)
        && validHealthSnapshot(request.resource.data.get('patientHealthSnapshot', null));

      // ── Path B: center staff / doctor walk-in or follow-up booking ────
      // Reception has no access to patient_health_profiles.
      // patientHealthSnapshot must always be null for Path B writes.
      // Payment may be unpaid (default) or paid-at-creation with audit trail.
      allow create: if isSignedIn()
        && request.resource.data.source in ['walk_in', 'reception', 'doctor_followup']
        && request.resource.data.bookedByUserId == request.auth.uid
        && isCenterMember(request.resource.data.centerId)
        && request.resource.data.status in ['pending', 'confirmed']
        && request.resource.data.visitStatus == 'waiting'
        && centerIsOperational(request.resource.data.centerId)
        && request.resource.data.get('patientHealthSnapshot', null) == null
        && isValidCreationPayment();

      // ── Doctor: update own appointment (status, visitStatus, notes) — paymentStatus excluded ─
      allow update: if isSignedIn()
        && resource.data.doctorId == request.auth.uid
        && appointmentCoreUnchanged()
        && !request.resource.data.diff(resource.data).affectedKeys().hasAny([
             'paymentStatus', 'paymentStatusUpdatedAt', 'paymentStatusUpdatedBy'
           ]);

      // ── Center staff: lifecycle updates (visitStatus, status, notes) ──────
      allow update: if isSignedIn()
        && isCenterMember(resource.data.centerId)
        && appointmentCoreUnchanged()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
             'visitStatus', 'status', 'notes',
             'updatedAt', 'confirmedAt', 'cancelledAt', 'completedAt'
           ]);

      // ── Center staff: payment marking (unpaid → paid, audit fields required) ─
      allow update: if appointmentCoreUnchanged()
        && isPaymentStatusUpdate(resource.data.centerId);

      // ── Patient: cancel own appointment only (pending or confirmed, not completed) ──
      allow update: if isSignedIn()
        && resource.data.patientId == request.auth.uid
        && resource.data.status != 'completed'
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
             'status', 'cancelledAt', 'updatedAt'
           ])
        && request.resource.data.status == 'cancelled';

      // ── Patient: mark own completed appointment as reviewed (one-way) ─
      allow update: if isSignedIn()
        && resource.data.patientId == request.auth.uid
        && resource.data.status == 'completed'
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
             'hasReviewed', 'updatedAt'
           ])
        && request.resource.data.hasReviewed == true;

      // ── Admin: full update access ──────────────────────────────────────
      allow update: if isAdmin();
    }


    // ───────────────────────────────────────────────────────────────────────
    // slot_locks/{slotId}
    //
    // Transient availability records — one per booked slot.
    // Created atomically with the appointment document at booking time.
    // Deleted atomically with the appointment status update at cancellation.
    //
    // SlotId format: '{scheduleId}_{slotStartAt.millisecondsSinceEpoch}'
    //
    // Presence  → slot is occupied.
    // Absence   → slot is available.
    //
    // Required fields written at create time:
    //   appointmentId — UUID of the linked appointment document
    //   centerId      — center scope (used for member permission check + index)
    //   dateKey       — YYYY-MM-DD (used for getBookedSlotIds index query)
    //   lockedBy      — request.auth.uid of the booking actor
    //   lockedAt      — FieldValue.serverTimestamp()
    //
    // Read:   any signed-in user — the booking transaction must read
    //         slot_locks/{slotId} to check availability before writing.
    // Create: any signed-in user who identifies themselves as the locker
    //         (lockedBy == auth.uid). Covers both patient self-booking and
    //         center-staff booking; appointment creation rules enforce the
    //         deeper source / role / ownership constraints atomically.
    // Delete: the original lock creator (lockedBy == auth.uid), the patient
    //         who owns the linked appointment (enables patient-initiated
    //         cancellation of reception-booked slots where lockedBy is staff),
    //         any active center member for that center, or admin.
    //         When resource == null the document does not exist; the delete is
    //         a no-op (walk-in appointments and pre-Phase-1 appointments have
    //         no slot_lock). Any signed-in user may safely attempt it.
    //         All cancellation surfaces delete the lock in the same batch/
    //         transaction as the appointment status update.
    // Update: never — locks are created and deleted only, not mutated.
    // ───────────────────────────────────────────────────────────────────────

    match /slot_locks/{slotId} {
      allow read: if isSignedIn();

      allow create: if isSignedIn()
        && request.resource.data.lockedBy == request.auth.uid
        && request.resource.data.centerId is string
        && request.resource.data.centerId.size() > 0
        && request.resource.data.appointmentId is string
        && request.resource.data.dateKey is string;

      allow delete: if isSignedIn()
        && (resource == null
            || resource.data.lockedBy == request.auth.uid
            || (resource.data.appointmentId is string
                && get(/databases/$(database)/documents/appointments/$(resource.data.appointmentId)).data.patientId == request.auth.uid)
            || isCenterMember(resource.data.centerId)
            || isAdmin());

      allow update: if false;
    }


    // ───────────────────────────────────────────────────────────────────────
    // patient_visit_notes/{appointmentId}
    //
    // Document ID == appointmentId (deterministic: one note per appointment).
    //
    // Privacy model:
    //   Doctor who wrote the note → get + list + create + update
    //   Admin                     → read (get + list) only
    //   Center staff/reception    → intentionally NO access (clinical notes)
    //   Patient app               → intentionally NO access (MVP)
    //
    // GET vs LIST split:
    //   get  — note may not exist yet (first visit). When resource == null,
    //          authorize via appointments/{appointmentId}.doctorId instead.
    //   list — history query; document always exists, so resource.data is safe.
    //
    // Immutable core fields: patientId, doctorId, centerId, appointmentId,
    //   createdAt, createdByUserId, createdByRole, schemaVersion
    // Mutable fields: clinicalNote, followUpNote, updatedAt
    // ───────────────────────────────────────────────────────────────────────

    match /patient_visit_notes/{appointmentId} {

      // GET a single note document (doctor or admin).
      // Case 1: note exists — verify doctorId ownership directly.
      // Case 2: note does not exist yet (first visit before any note is saved) —
      //         cross-reference the appointment document to verify ownership.
      //         noteId == appointmentId so no extra lookup key is needed.
      //         Cost: 1 extra read on appointments/{appointmentId} only when
      //         the note is absent; zero extra reads once the note exists.
      allow get: if isSignedIn() && (
          (resource != null && resource.data.doctorId == request.auth.uid)
          || (resource == null
              && get(/databases/$(database)/documents/appointments/$(appointmentId)).data.doctorId == request.auth.uid)
        );

      // LIST (patient history query) — documents always exist in queries,
      // so resource.data is safe. Doctor sees only their own notes.
      allow list: if isSignedIn()
        && resource.data.doctorId == request.auth.uid;

      // Admin can get + list all notes.
      allow read: if isAdmin();

      // Doctor creates a note — ownership + schema validation.
      // appointmentId field must match the document ID to prevent ID spoofing.
      allow create: if isSignedIn()
        && isDoctor()
        && request.resource.data.doctorId == request.auth.uid
        && request.resource.data.appointmentId == appointmentId
        && request.resource.data.createdByUserId == request.auth.uid
        && request.resource.data.createdByRole == 'doctor'
        && request.resource.data.schemaVersion == 1
        && request.resource.data.clinicalNote is string;

      // Doctor may update only the clinical content of their own note.
      allow update: if isSignedIn()
        && resource.data.doctorId == request.auth.uid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
             'clinicalNote', 'followUpNote', 'updatedAt'
           ]);

      // Notes are permanent records — no client-side delete.
    }


    // ───────────────────────────────────────────────────────────────────────
    // patient_health_profiles/{patientId}
    //
    // Optional health context entered by the patient: date of birth, gender,
    // blood type, allergies, chronic conditions, current medications.
    //
    // Privacy model:
    //   Patient    → get own document only (no list — prevents enumeration)
    //   Admin      → read only (compliance audit)
    //   Doctor     → NO direct access to this collection
    //   Reception  → NO access
    //
    // Doctors read health data only through appointments/{id}.patientHealthSnapshot,
    // which is embedded at booking time for self-bookings.
    // This prevents any doctor from listing or querying all patients' health profiles.
    //
    // Document ID == patientId (one document per patient, deterministic).
    //
    // Immutable after creation: patientId, schemaVersion
    // Mutable:                  dateOfBirth, gender, bloodType, allergies,
    //                           chronicConditions, currentMedications, updatedAt
    // ───────────────────────────────────────────────────────────────────────

    match /patient_health_profiles/{patientId} {

      // Patient reads only their own profile.
      // 'get' only — 'list' is intentionally absent to block collection enumeration.
      allow get: if isSignedIn()
        && request.auth.uid == patientId;

      // Patient creates their own profile.
      // patientId field must match document ID and caller uid.
      // schemaVersion must be 1 on creation.
      allow create: if isSignedIn()
        && request.auth.uid == patientId
        && request.resource.data.patientId == patientId
        && request.resource.data.schemaVersion == 1;

      // Patient updates mutable fields only.
      // patientId and schemaVersion cannot change after creation.
      allow update: if isSignedIn()
        && request.auth.uid == patientId
        && request.resource.data.patientId == resource.data.patientId
        && request.resource.data.schemaVersion == resource.data.schemaVersion
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
             'dateOfBirth', 'gender', 'bloodType',
             'allergies', 'chronicConditions', 'currentMedications',
             'updatedAt'
           ]);

      // No client-side delete — patients clear data by nulling fields via update.
      allow delete: if false;

      // Admin read for compliance audit.
      allow read: if isAdmin();
    }


    // ───────────────────────────────────────────────────────────────────────
    // medical_centers/{centerId}
    //
    // Read:   public for active centers (isActive == true); inactive centers private
    // Create: doctor only; ownerId must match caller; billing fields allowed on
    //         initial creation (doctor sets subscriptionStatus, trialStart, etc.)
    // Update: center owner may update profile fields BUT NOT billing/subscription
    //         fields (those are admin-only to prevent self-upgrade fraud).
    //         Admin may update any field (subscription activation on payment).
    //
    // Subcollection: medical_centers/{centerId}/members/{uid}
    // ───────────────────────────────────────────────────────────────────────

    match /medical_centers/{centerId} {
      // Active centers: public read (no auth required) — used for center discovery.
      // Owner/member: can read even when isActive == false (e.g. billing page on inactive center).
      // resource == null: allow GET on non-existent docs (returns exists=false, not permission-denied).
      allow read: if resource == null
        || resource.data.get('isActive', false) == true
        || (isSignedIn() && resource.data.ownerId == request.auth.uid)
        || (isSignedIn() && isCenterMember(centerId));

      // Billing fields permitted on creation (doctor sets up initial trial).
      // These same fields are blocked from updates by the owner below.
      allow create: if isDoctor()
        && request.resource.data.ownerId == request.auth.uid;

      // accountLifecycle is controlled exclusively by Cloud Functions (admin SDK).
      allow update: if !touchesLifecycle()
        && (isAdmin()
            || (isSignedIn()
                && resource.data.ownerId == request.auth.uid
                && !request.resource.data.diff(resource.data).affectedKeys().hasAny([
                     'subscriptionStatus', 'centerStatus',
                     'trialStart', 'trialEnds',
                     'nextBillingDate', 'subscriptionStart', 'subscriptionEnd',
                     'currentPlan', 'billingCycle', 'paymentProvider',
                     'subscriptionVersion', 'lastPaymentAt', 'ownerId'
                   ]))
            // Scoped center admin may update non-billing fields (e.g. doctorCount).
            || (isCenterAdminForCenter(centerId)
                && !request.resource.data.diff(resource.data).affectedKeys().hasAny([
                     'subscriptionStatus', 'centerStatus',
                     'trialStart', 'trialEnds',
                     'nextBillingDate', 'subscriptionStart', 'subscriptionEnd',
                     'currentPlan', 'billingCycle', 'paymentProvider',
                     'subscriptionVersion', 'lastPaymentAt', 'ownerId'
                   ])));


      // ── medical_centers/{centerId}/members/{uid} ───────────────────────
      // Read:  center members, the center owner, or admin
      // Write: center owner or admin only (prevents doctors self-joining)
      //
      // Founder exception: when a doctor creates their own practice, the
      // medical_centers doc and this member doc are written in the same
      // client transaction. Rule evaluation reads committed DB state, so
      // the center doc does not exist yet → isCenterOwner returns false.
      // The !exists() guard closes this path permanently once the center
      // is committed — no doctor can use it to join an existing center.
      match /members/{memberId} {
        allow read: if isSignedIn()
          && (isCenterMember(centerId)
              || isCenterOwner(centerId)
              || isAdmin());

        // Founder self-membership: own practice creation only.
        // !exists() is true only while the center has not been committed.
        allow create: if isDoctor()
          && request.resource.data.uid == request.auth.uid
          && request.resource.data.role == 'center_admin'
          && request.resource.data.isActive == true
          && !exists(/databases/$(database)/documents/medical_centers/$(centerId));

        // accountLifecycle on member documents is controlled by lifecycle Cloud Functions only.
        allow write: if !touchesLifecycle()
          && (isCenterOwner(centerId) || isAdmin() || isCenterAdminForCenter(centerId));
      }
    }


    // ───────────────────────────────────────────────────────────────────────
    // account_deletion_log/{eventId}
    //
    // Compliance audit trail — 7-year retention.
    // Written exclusively by lifecycle Cloud Functions via admin SDK.
    // No client read or write permitted.
    // ───────────────────────────────────────────────────────────────────────

    match /account_deletion_log/{eventId} {
      allow read, write: if false;
    }


    // ───────────────────────────────────────────────────────────────────────
    // account_deletion_requests/{requestId}
    //
    // Analytics and support layer — 3-year retention, aggregate-and-purge after 3 years.
    // Written exclusively by lifecycle Cloud Functions via admin SDK.
    // No client read or write permitted.
    // ───────────────────────────────────────────────────────────────────────

    match /account_deletion_requests/{requestId} {
      allow read, write: if false;
    }


    // ───────────────────────────────────────────────────────────────────────
    // payments/{paymentId}
    //
    // Read:   own payment (userId match) or center owner or admin
    // Create: authenticated user for their own payment (initiating subscription)
    // Update: admin always; client may submit (declared→under_review) or renew (completed→declared)
    // ───────────────────────────────────────────────────────────────────────

    match /payments/{paymentId} {
      allow read: if isSignedIn()
        && (resource == null
            || resource.data.uid == request.auth.uid
            || resource.data.userId == request.auth.uid
            || (resource.data.get('centerId', null) is string
                && resource.data.get('centerId', '').size() > 0
                && (isCenterOwner(resource.data.get('centerId', ''))
                    || isCenterAdminMember(resource.data.get('centerId', ''))))
            || isAdmin());

      allow create: if isSignedIn()
        && (request.resource.data.userId == request.auth.uid
            || request.resource.data.uid == request.auth.uid);

      // Scoped client update: payment creator may submit (declared → under_review).
      // All other status transitions remain admin/server-only.
      allow update: if isAdmin()
        // Step 2: submit for review after declaring intent
        || (isSignedIn()
            && resource.data.uid == request.auth.uid
            && resource.data.status == 'declared'
            && request.resource.data.status == 'under_review'
            && request.resource.data.diff(resource.data).affectedKeys()
                 .hasOnly(['status', 'updatedAt']))
        // Renewal: center owner may re-initiate payment from a completed cycle.
        // The open payment doc (open_center_{centerId}) is reused across renewals.
        // .set(merge:true) on an existing doc evaluates as update in rules.
        // Target may be awaiting_transfer (new canonical) or declared (legacy);
        // activation still requires admin approval in both cases.
        || (isSignedIn()
            && (resource.data.uid == request.auth.uid
                || (resource.data.centerId is string
                    && resource.data.centerId.size() > 0
                    && isCenterOwner(resource.data.centerId)))
            && resource.data.status == 'completed'
            && request.resource.data.status in ['awaiting_transfer', 'declared']
            && request.resource.data.centerId == resource.data.centerId
            && request.resource.data.uid == request.auth.uid
            && request.resource.data.userId == request.auth.uid)
        // Confirm transfer: doctor marks awaiting_transfer payment as sent.
        // Only the original submitter may do this. hasOnly prevents writing
        // activation fields; actual activation still requires admin approval.
        || (isSignedIn()
            && resource.data.uid == request.auth.uid
            && resource.data.status == 'awaiting_transfer'
            && request.resource.data.status == 'under_review'
            && request.resource.data.diff(resource.data).affectedKeys()
                 .hasOnly(['status', 'submittedAt', 'updatedAt']))
        // Resubmit after rejection: original submitter or current center owner may
        // restart a rejected open payment doc. centerId is immutable; target may be
        // awaiting_transfer (new canonical) or declared (backward compat for legacy
        // clients). Activation still requires admin approval in both cases.
        || (isSignedIn()
            && (resource.data.uid == request.auth.uid
                || (resource.data.centerId is string
                    && resource.data.centerId.size() > 0
                    && isCenterOwner(resource.data.centerId)))
            && resource.data.status == 'rejected'
            && request.resource.data.status in ['awaiting_transfer', 'declared']
            && request.resource.data.centerId == resource.data.centerId
            && request.resource.data.uid == request.auth.uid);
    }


    // ───────────────────────────────────────────────────────────────────────
    // center_join_requests/{requestId}
    //
    // Doc ID pattern: '{centerId}_{doctorId}'
    // Read:   the requesting doctor, the center owner, or admin
    // Create: doctor only; doctorId must match caller; initial status must be 'pending'
    // Update: center owner or admin (to approve / reject)
    // ───────────────────────────────────────────────────────────────────────

    match /center_join_requests/{requestId} {
      allow read: if isSignedIn()
        && (resource.data.doctorId == request.auth.uid
            || isCenterOwner(resource.data.centerId)
            || isCenterAdminForCenter(resource.data.centerId)
            || isAdmin());

      allow create: if isDoctor()
        && request.resource.data.doctorId == request.auth.uid
        && request.resource.data.status == 'pending';

      allow update: if isCenterOwner(resource.data.centerId)
        || isCenterAdminForCenter(resource.data.centerId)
        || isAdmin();
    }


    // ───────────────────────────────────────────────────────────────────────
    // national_ids/{nationalId}
    //
    // Doc ID = normalized national ID number (digits only, Arabic/Persian
    // numerals converted to ASCII). Used solely to prevent duplicate doctor
    // registrations via an atomic read-then-write transaction.
    //
    // Read:   authenticated doctor — uniqueness check during onboarding submit
    // Create: the submitting doctor; doctorId field must equal caller's uid
    // Update/Delete: admin only — locks are permanent after creation
    //
    // Privacy note: doc ID is the raw national ID number. A future hardening
    // pass should replace it with SHA-256(nationalId + projectSalt).
    // ───────────────────────────────────────────────────────────────────────

    match /national_ids/{nationalId} {
      allow read: if isDoctor();

      allow create: if isDoctor()
        && request.resource.data.doctorId == request.auth.uid;

      allow update, delete: if isAdmin();
    }


    // ───────────────────────────────────────────────────────────────────────
    // shiftTemplates/{templateId}
    //
    // Doctor portal only. Each template belongs to one doctor (doctorId field).
    // ───────────────────────────────────────────────────────────────────────

    match /shiftTemplates/{templateId} {
      allow read: if isDoctor()
        && resource.data.doctorId == request.auth.uid;

      allow create: if isDoctor()
        && request.resource.data.doctorId == request.auth.uid;

      allow update, delete: if isDoctor()
        && resource.data.doctorId == request.auth.uid;
    }


    // ───────────────────────────────────────────────────────────────────────
    // External import collections  (admin read only)
    // Used by mydoctor_admin for the doctor import workflow.
    // ───────────────────────────────────────────────────────────────────────

    match /google_doctors/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /public_doctors/{doctorId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /facebook_doctors/{id} {
      allow read: if isAdmin();
    }


    // ───────────────────────────────────────────────────────────────────────
    // Collection group: members
    //
    // Authorizes collectionGroup('members').where('uid', isEqualTo: uid)
    // queries fired on startup to resolve staff identity.
    // A user may only read member documents where uid == their own auth uid.
    // Write access is not granted here — governed by the nested rule only.
    // ───────────────────────────────────────────────────────────────────────

    match /{path=**}/members/{memberId} {
      allow read: if isSignedIn()
        && resource.data.uid == request.auth.uid;
    }


    // ───────────────────────────────────────────────────────────────────────
    // Intentionally unmatched collections (implicit deny):
    //
    //   patients   — doctor portal uses 'users', not 'patients'. If this
    //                collection contains data, it is inaccessible from clients.
    //
    //   slotUsage  — purpose unclear; add an explicit rule before opening.
    //
    // OPEN SECURITY NOTE (blocker #9, not fixable via Firestore rules):
    //   zaincashCallback HTTP Cloud Function has no Firebase Auth check.
    //   It relies on ZainCash JWT verification only. Before going to
    //   production, add HMAC signature verification or an IP allowlist.
    // ───────────────────────────────────────────────────────────────────────

  }
}
